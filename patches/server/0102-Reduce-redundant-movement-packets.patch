+    private void sendVelocityPacket(final int entityId, final Vec3 velocity, final boolean includeSelf) {
+        final int xa = Mth.clamp((int) (velocity.x * 8000.0D), -31200, 31200);
+        final int ya = Mth.clamp((int) (velocity.y * 8000.0D), -31200, 31200);
+        final int za = Mth.clamp((int) (velocity.z * 8000.0D), -31200, 31200);
+        if (EntropyConfig.skipRedundantVelocityPackets && this.lastVelocityTick == this.tickCount && this.lastVelocityXa == xa && this.lastVelocityYa == ya && this.lastVelocityZa == za) {
+            return;
+        }
+
+        this.lastVelocityTick = this.tickCount;
+        this.lastVelocityXa = xa;
+        this.lastVelocityYa = ya;
+        this.lastVelocityZa = za;
+
+        final ClientboundSetEntityMotionPacket packet = new ClientboundSetEntityMotionPacket(entityId, velocity);
+        if (includeSelf) {
+            this.broadcastAndSend(packet);
+        } else {
+            this.broadcast.accept(packet);
+        }
+    }
+
