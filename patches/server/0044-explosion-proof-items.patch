diff --git a/src/main/java/xyz/fragmentmc/entropy/ExplosionProofItems.java b/src/main/java/xyz/fragmentmc/entropy/ExplosionProofItems.java
new file mode 100644
index 0000000000000000000000000000000000000000..9c87e383693134184c4aa50bef91e1720761596c
--- /dev/null
+++ b/src/main/java/xyz/fragmentmc/entropy/ExplosionProofItems.java
@@ -0,0 +1,25 @@
+package xyz.fragmentmc.entropy;
+
+
+import net.minecraft.world.entity.item.ItemEntity;
+import org.bukkit.Material;
+
+import java.util.HashSet;
+
+public class ExplosionProofItems {
+    private static HashSet<Material> explosionProofItems = new HashSet<>();
+    private static boolean explodeNone = false;
+    private static boolean explodeAll = true;
+
+    public static boolean shouldExplodeItem(ItemEntity item) {
+        if(explodeAll) return true;
+        if (explodeNone) return false;
+        return !explosionProofItems.contains(item.getItem().getBukkitStack().getType());
+    }
+
+    public static void loadFromConfig() {
+        explodeAll = EntropyConfig.explosionProofList.isEmpty();
+        explodeNone = EntropyConfig.explosionProofList.contains("*");
+        explosionProofItems = ConfigUtil.materialsFromNames(EntropyConfig.explosionProofList);
+    }
+}
