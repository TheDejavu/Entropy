diff --git a/src/main/java/xyz/fragmentmc/entropy/ConfigUtil.java b/src/main/java/xyz/fragmentmc/entropy/ConfigUtil.java
new file mode 100644
index 0000000000000000000000000000000000000000..dbecdfbeae313c43e4a341e2113e4362e5db9404
--- /dev/null
+++ b/src/main/java/xyz/fragmentmc/entropy/ConfigUtil.java
@@ -0,0 +1,19 @@
+package xyz.fragmentmc.entropy;
+
+import org.bukkit.Material;
+
+import java.util.HashSet;
+import java.util.List;
+import java.util.Objects;
+
+public class ConfigUtil {
+    public static HashSet<Material> materialsFromNames(List<String> names) {
+        HashSet<Material> set = new HashSet<>();
+        for(String n : names) {
+            if(!Objects.equals(n, "*")) {
+                set.add(org.bukkit.Material.valueOf(n.toUpperCase()));
+            }
+        }
+        return set;
+    }
+}
