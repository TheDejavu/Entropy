diff --git a/src/main/java/dev/orhidea/starforge/connection/NetDebugReport.java b/src/main/java/dev/orhidea/starforge/connection/NetDebugReport.java
new file mode 100644
index 0000000000000000000000000000000000000000..e0efbbfa4a1a05429d51a06fb5886340bf215680
--- /dev/null
+++ b/src/main/java/dev/orhidea/starforge/connection/NetDebugReport.java
@@ -0,0 +1,207 @@
+package dev.orhidea.starforge.connection;
+
+import com.mojang.logging.LogUtils;
+import dev.orhidea.starforge.EntropyConfig;
+import net.minecraft.network.Connection;
+import net.minecraft.network.PacketListener;
+import net.minecraft.network.chat.Component;
+import net.minecraft.server.MinecraftServer;
+import net.minecraft.server.level.ServerPlayer;
+import net.minecraft.server.network.ServerCommonPacketListenerImpl;
+import org.slf4j.Logger;
+
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+import java.util.Locale;
+import java.util.concurrent.atomic.AtomicLong;
+
+public final class NetDebugReport {
+    private static final Logger LOGGER = LogUtils.getLogger();
+    private static final AtomicLong NEXT_TIMEOUT_REPORT_AT = new AtomicLong();
+
+    private NetDebugReport() {
+    }
+
+    public static List<ConnectionSnapshot> collect(MinecraftServer server) {
+        final List<ConnectionSnapshot> snapshots = new ArrayList<>();
+        final List<Connection> connections = server.getConnection().getConnections();
+
+        for (final Connection connection : connections) {
+            final ServerPlayer player = connection.getPlayer();
+            final PacketListener packetListener = connection.getPacketListener();
+            if (player == null || !(packetListener instanceof ServerCommonPacketListenerImpl commonPacketListener)) {
+                continue;
+            }
+
+            snapshots.add(ConnectionSnapshot.from(player, connection, commonPacketListener));
+        }
+
+        snapshots.sort(Comparator
+            .comparingInt(ConnectionSnapshot::pendingActions).reversed()
+            .thenComparing(ConnectionSnapshot::keepAlivePending).reversed()
+            .thenComparingLong(ConnectionSnapshot::keepAliveAgeMillis).reversed()
+            .thenComparingInt(ConnectionSnapshot::avgSentPackets).reversed());
+        return snapshots;
+    }
+
+    public static int sendToSource(net.minecraft.commands.CommandSourceStack source, int limit) {
+        final List<Connection> connections = source.getServer().getConnection().getConnections();
+        final List<ConnectionSnapshot> snapshots = collect(source.getServer());
+
+        source.sendSuccess(() -> Component.literal(
+            "NetDebug: totalConnections=" + connections.size()
+                + " playerConnections=" + snapshots.size()
+                + " altKeepAlive=" + EntropyConfig.useAlternateKeepAlive
+        ), false);
+
+        if (snapshots.isEmpty()) {
+            source.sendSuccess(() -> Component.literal("No active player connections."), false);
+            return 0;
+        }
+
+        final int shown = Math.min(limit, snapshots.size());
+        for (int index = 0; index < shown; ++index) {
+            final ConnectionSnapshot snapshot = snapshots.get(index);
+            final int rank = index + 1;
+            source.sendSuccess(() -> Component.literal(snapshot.format(rank)), false);
+        }
+        return shown;
+    }
+
+    public static void logFirstTimeout(MinecraftServer server, ServerCommonPacketListenerImpl timedOutListener) {
+        if (!EntropyConfig.timeoutDebugReportEnabled) {
+            return;
+        }
+
+        final long currentTime = net.minecraft.Util.getMillis();
+        final long nextAllowed = NEXT_TIMEOUT_REPORT_AT.get();
+        if (currentTime < nextAllowed) {
+            return;
+        }
+
+        final long cooldownMillis = Math.max(1L, EntropyConfig.timeoutDebugReportCooldownSeconds) * 1000L;
+        if (!NEXT_TIMEOUT_REPORT_AT.compareAndSet(nextAllowed, currentTime + cooldownMillis)) {
+            return;
+        }
+
+        final List<Connection> connections = server.getConnection().getConnections();
+        final List<ConnectionSnapshot> snapshots = collect(server);
+        final ServerPlayer timedOutPlayer = timedOutListener.connection.getPlayer();
+        if (timedOutPlayer == null) {
+            return;
+        }
+        final ConnectionSnapshot timedOutSnapshot = ConnectionSnapshot.from(timedOutPlayer, timedOutListener.connection, timedOutListener);
+
+        int pendingKeepAliveConnections = 0;
+        long totalQueuedPackets = 0L;
+        long totalImmediatePackets = 0L;
+        long totalFlushCalls = 0L;
+        long totalAvgOut = 0L;
+        int maxAvgOut = 0;
+
+        for (final ConnectionSnapshot snapshot : snapshots) {
+            if (snapshot.keepAlivePending()) {
+                ++pendingKeepAliveConnections;
+            }
+            totalQueuedPackets += snapshot.queuedPackets();
+            totalImmediatePackets += snapshot.immediatePackets();
+            totalFlushCalls += snapshot.flushCalls();
+            totalAvgOut += snapshot.avgSentPackets();
+            maxAvgOut = Math.max(maxAvgOut, snapshot.avgSentPackets());
+        }
+
+        final long averageAvgOut = snapshots.isEmpty() ? 0L : Math.round((double) totalAvgOut / (double) snapshots.size());
+        LOGGER.warn(
+            "TimeoutDebug: player={} ping={}ms keepalive={} totalConnections={} playerConnections={} altKeepAlive={}",
+            timedOutSnapshot.playerName(),
+            timedOutSnapshot.ping(),
+            timedOutSnapshot.keepAlivePending()
+                ? "pending " + timedOutSnapshot.keepAliveAgeMillis() + "/" + timedOutSnapshot.keepAliveLimitMillis() + "ms queued=" + timedOutSnapshot.pendingKeepAlives()
+                : "clear",
+            connections.size(),
+            snapshots.size(),
+            EntropyConfig.useAlternateKeepAlive
+        );
+        LOGGER.warn(
+            "TimeoutDebug: pendingKeepAliveConnections={} avgOut={} maxOut={} queuedTotal={} immediateTotal={} flushes={}",
+            pendingKeepAliveConnections,
+            averageAvgOut,
+            maxAvgOut,
+            totalQueuedPackets,
+            totalImmediatePackets,
+            totalFlushCalls
+        );
+
+        final int shown = Math.min(EntropyConfig.timeoutDebugReportConnectionLimit, snapshots.size());
+        for (int index = 0; index < shown; ++index) {
+            LOGGER.warn("TimeoutDebug: {}", snapshots.get(index).format(index + 1));
+        }
+    }
+
+    public record ConnectionSnapshot(
+        String playerName,
+        int ping,
+        int pendingActions,
+        int maxPendingActions,
+        int avgSentPackets,
+        int avgReceivedPackets,
+        long queuedPackets,
+        long immediatePackets,
+        long flushCalls,
+        boolean keepAlivePending,
+        int pendingKeepAlives,
+        long keepAliveAgeMillis,
+        long keepAliveLimitMillis,
+        boolean writable,
+        long bytesBeforeUnwritable
+    ) {
+        public static ConnectionSnapshot from(ServerPlayer player, Connection connection, ServerCommonPacketListenerImpl commonPacketListener) {
+            return new ConnectionSnapshot(
+                player.getGameProfile().getName(),
+                commonPacketListener.latency(),
+                connection.getPendingActionCount(),
+                connection.getMaxPendingActionCount(),
+                Math.round(connection.getAverageSentPackets()),
+                Math.round(connection.getAverageReceivedPackets()),
+                connection.getQueuedPacketCount(),
+                connection.getImmediatePacketCount(),
+                connection.getFlushCallCount(),
+                commonPacketListener.isKeepAlivePendingForDebug(),
+                commonPacketListener.getPendingKeepAliveCountForDebug(),
+                commonPacketListener.getKeepAliveAgeMillisForDebug(),
+                commonPacketListener.getKeepAliveLimitMillisForDebug(),
+                connection.isChannelWritableForDebug(),
+                connection.getBytesBeforeUnwritableForDebug()
+            );
+        }
+
+        public String format(int rank) {
+            return "#" + rank
+                + " " + this.playerName
+                + " ping=" + this.ping + "ms"
+                + " queue=" + this.pendingActions + "/" + this.maxPendingActions
+                + " avgOut=" + this.avgSentPackets
+                + " avgIn=" + this.avgReceivedPackets
+                + " queuedTotal=" + this.queuedPackets
+                + " immediateTotal=" + this.immediatePackets
+                + " flushes=" + this.flushCalls
+                + " keepalive=" + (this.keepAlivePending ? ("pending " + this.keepAliveAgeMillis + "/" + this.keepAliveLimitMillis + "ms queued=" + this.pendingKeepAlives) : "clear")
+                + " writable=" + this.writable
+                + " beforeUnwritable=" + formatBytes(this.bytesBeforeUnwritable);
+        }
+
+        private static String formatBytes(long bytes) {
+            if (bytes < 0L) {
+                return "n/a";
+            }
+            if (bytes < 1024L) {
+                return bytes + "B";
+            }
+            if (bytes < 1024L * 1024L) {
+                return String.format(Locale.ROOT, "%.1fKiB", bytes / 1024.0D);
+            }
+            return String.format(Locale.ROOT, "%.1fMiB", bytes / (1024.0D * 1024.0D));
+        }
+    }
+}
