diff --git a/src/main/java/net/minecraft/server/players/PlayerList.java b/src/main/java/net/minecraft/server/players/PlayerList.java
index 9666b114b5a4c2b436eb3900e7a905327a4c65cd..b580bd8354c2ee09478be29c64a61eeed9ab012a 100644
--- a/src/main/java/net/minecraft/server/players/PlayerList.java
+++ b/src/main/java/net/minecraft/server/players/PlayerList.java
@@ -141,6 +141,7 @@ public abstract class PlayerList {
     private final MinecraftServer server;
     public final List<ServerPlayer> players = new java.util.concurrent.CopyOnWriteArrayList(); // CraftBukkit - ArrayList -> CopyOnWriteArrayList: Iterator safety
     private volatile ServerPlayer[] playersView = EMPTY_PLAYERS;
+    private final ServerPlayer[][] sendAllPlayerInfoBuckets = new ServerPlayer[PlayerList.SEND_PLAYER_INFO_INTERVAL][];
     private final Map<UUID, ServerPlayer> playersByUUID = Maps.newHashMap();
     private final UserBanList bans;
     private final IpBanList ipBans;
@@ -192,6 +193,51 @@ public abstract class PlayerList {
         this.playersView = this.players.toArray(EMPTY_PLAYERS);
     }
 
+    private static int getSendAllPlayerInfoBucketIndex(ServerPlayer player) {
+        return Math.floorMod(player.getUUID().hashCode(), PlayerList.SEND_PLAYER_INFO_INTERVAL);
+    }
+
+    private void addToSendAllPlayerInfoBucket(ServerPlayer player) {
+        final int bucketIndex = PlayerList.getSendAllPlayerInfoBucketIndex(player);
+        final ServerPlayer[] bucket = this.sendAllPlayerInfoBuckets[bucketIndex];
+
+        if (bucket == null) {
+            this.sendAllPlayerInfoBuckets[bucketIndex] = new ServerPlayer[] {player};
+            return;
+        }
+
+        final int length = bucket.length;
+        final ServerPlayer[] expanded = java.util.Arrays.copyOf(bucket, length + 1);
+
+        expanded[length] = player;
+        this.sendAllPlayerInfoBuckets[bucketIndex] = expanded;
+    }
+
+    private void removeFromSendAllPlayerInfoBucket(ServerPlayer player) {
+        final int bucketIndex = PlayerList.getSendAllPlayerInfoBucketIndex(player);
+        final ServerPlayer[] bucket = this.sendAllPlayerInfoBuckets[bucketIndex];
+
+        if (bucket == null) {
+            return;
+        }
+
+        final int length = bucket.length;
+        if (length == 1) {
+            if (bucket[0] == player) {
+                this.sendAllPlayerInfoBuckets[bucketIndex] = null;
+            }
+            return;
+        }
+
+        for (int i = 0; i < length; ++i) {
+            if (bucket[i] == player) {
+                bucket[i] = bucket[length - 1];
+                this.sendAllPlayerInfoBuckets[bucketIndex] = java.util.Arrays.copyOf(bucket, length - 1);
+                return;
+            }
+        }
+    }
+
     public void placeNewPlayer(Connection connection, ServerPlayer player, CommonListenerCookie clientData) {
         player.isRealPlayer = true; // Paper
         player.loginTime = System.currentTimeMillis(); // Paper - Replace OfflinePlayer#getLastPlayed
@@ -338,6 +384,7 @@ public abstract class PlayerList {
 
         // entityplayer.connection.send(ClientboundPlayerInfoUpdatePacket.createPlayerInitializing(this.players)); // CraftBukkit - replaced with loop below
         this.players.add(player);
+        this.addToSendAllPlayerInfoBucket(player);
         this.refreshPlayersView();
         this.playersByName.put(player.getScoreboardName().toLowerCase(java.util.Locale.ROOT), player); // Spigot
         this.playersByUUID.put(player.getUUID(), player);
@@ -676,6 +723,7 @@ public abstract class PlayerList {
         entityplayer.retireScheduler(); // Paper - Folia schedulers
         entityplayer.getAdvancements().stopListening();
         this.players.remove(entityplayer);
+        this.removeFromSendAllPlayerInfoBucket(entityplayer);
         this.refreshPlayersView();
         this.playersByName.remove(entityplayer.getScoreboardName().toLowerCase(java.util.Locale.ROOT)); // Spigot
         this.server.getCustomBossEvents().onPlayerDisconnect(entityplayer);
@@ -837,6 +885,7 @@ public abstract class PlayerList {
         // Paper end - Expand PlayerRespawnEvent
         entityplayer.stopRiding(); // CraftBukkit
         this.players.remove(entityplayer);
+        this.removeFromSendAllPlayerInfoBucket(entityplayer);
         this.refreshPlayersView();
         this.playersByName.remove(entityplayer.getScoreboardName().toLowerCase(java.util.Locale.ROOT)); // Spigot
         entityplayer.serverLevel().removePlayerImmediately(entityplayer, Entity.RemovalReason.DISCARDED);
@@ -974,6 +1023,7 @@ public abstract class PlayerList {
         if (!entityplayer.connection.isDisconnected()) {
             worldserver1.addRespawnedPlayer(entityplayer1);
             this.players.add(entityplayer1);
+            this.addToSendAllPlayerInfoBucket(entityplayer1);
             this.refreshPlayersView();
             this.playersByName.put(entityplayer1.getScoreboardName().toLowerCase(java.util.Locale.ROOT), entityplayer1); // Spigot
             this.playersByUUID.put(entityplayer1.getUUID(), entityplayer1);
@@ -1034,41 +1084,47 @@ public abstract class PlayerList {
     }
 
     public void tick() {
-        if (++this.sendAllPlayerInfoIn > PlayerList.SEND_PLAYER_INFO_INTERVAL) {
+        final ServerPlayer[] bucket = this.sendAllPlayerInfoBuckets[this.sendAllPlayerInfoIn];
+        if (bucket != null) {
             final ServerPlayer[] playerArray = this.getPlayersArray();
             final int playerCount = playerArray.length;
-            final CraftPlayer[] bukkitPlayers = new CraftPlayer[playerCount];
             boolean hasVisibilityInversions = false;
 
             for (int i = 0; i < playerCount; ++i) {
-                final CraftPlayer craftPlayer = playerArray[i].getBukkitEntity();
-                bukkitPlayers[i] = craftPlayer;
-                hasVisibilityInversions |= craftPlayer.hasVisibilityInversions();
+                if (playerArray[i].getBukkitEntity().hasVisibilityInversions()) {
+                    hasVisibilityInversions = true;
+                    break;
+                }
             }
 
             if (!hasVisibilityInversions) {
                 final ClientboundPlayerInfoUpdatePacket packet = new ClientboundPlayerInfoUpdatePacket(PlayerList.UPDATE_LATENCY_ACTION, List.of(playerArray));
+                for (int i = 0, length = bucket.length; i < length; ++i) {
+                    bucket[i].connection.send(packet);
+                }
+            } else {
+                final UUID[] playerUuids = new UUID[playerCount];
                 for (int i = 0; i < playerCount; ++i) {
-                    playerArray[i].connection.send(packet);
+                    playerUuids[i] = playerArray[i].getUUID();
                 }
-                this.sendAllPlayerInfoIn = 0;
-                return;
-            }
 
-            for (int i = 0; i < playerCount; ++i) {
-                final ServerPlayer target = playerArray[i];
-                final CraftPlayer targetBukkit = bukkitPlayers[i];
-                final List<ServerPlayer> visiblePlayers = Lists.newArrayListWithExpectedSize(playerCount);
+                for (int i = 0, bucketLength = bucket.length; i < bucketLength; ++i) {
+                    final ServerPlayer target = bucket[i];
+                    final CraftPlayer targetBukkit = target.getBukkitEntity();
+                    final List<ServerPlayer> visiblePlayers = Lists.newArrayListWithExpectedSize(playerCount);
 
-                for (int j = 0; j < playerCount; ++j) {
-                    if (targetBukkit.canSee(bukkitPlayers[j])) {
-                        visiblePlayers.add(playerArray[j]);
+                    for (int j = 0; j < playerCount; ++j) {
+                        if (targetBukkit.canSee(playerUuids[j])) {
+                            visiblePlayers.add(playerArray[j]);
+                        }
                     }
-                }
 
-                target.connection.send(new ClientboundPlayerInfoUpdatePacket(PlayerList.UPDATE_LATENCY_ACTION, visiblePlayers));
+                    target.connection.send(new ClientboundPlayerInfoUpdatePacket(PlayerList.UPDATE_LATENCY_ACTION, visiblePlayers));
+                }
             }
+        }
 
+        if (++this.sendAllPlayerInfoIn >= PlayerList.SEND_PLAYER_INFO_INTERVAL) {
             this.sendAllPlayerInfoIn = 0;
         }
 
@@ -1557,15 +1613,6 @@ public abstract class PlayerList {
             File file = this.server.getWorldPath(LevelResource.PLAYER_STATS_DIR).toFile();
             File file1 = new File(file, uuid + ".json");
 
-            if (!file1.exists()) {
-                File file2 = new File(file, displayName + ".json"); // CraftBukkit
-                Path path = file2.toPath();
-
-                if (FileUtil.isPathNormalized(path) && FileUtil.isPathPortable(path) && path.startsWith(file.getPath()) && file2.isFile()) {
-                    file2.renameTo(file1);
-                }
-            }
-
             serverstatisticmanager = new ServerStatsCounter(this.server, file1);
             // this.stats.put(uuid, serverstatisticmanager); // CraftBukkit
         }
