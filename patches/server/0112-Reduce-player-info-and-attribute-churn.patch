diff --git a/src/main/java/org/bukkit/craftbukkit/scoreboard/CraftScoreboardManager.java b/src/main/java/org/bukkit/craftbukkit/scoreboard/CraftScoreboardManager.java
index 2a5a8d132e371e7e5e2d4ea6af7eed92f679bd6d..9d26dfb2a21abba2bed0c8c5dcabc111f0f44407 100644
--- a/src/main/java/org/bukkit/craftbukkit/scoreboard/CraftScoreboardManager.java
+++ b/src/main/java/org/bukkit/craftbukkit/scoreboard/CraftScoreboardManager.java
@@ -32,6 +32,7 @@ public final class CraftScoreboardManager implements ScoreboardManager {
     private final Map<CraftPlayer, CraftScoreboard> playerBoards = new HashMap<>();
     private final Set<Scoreboard> trackedScoreboards = Collections.newSetFromMap(new WeakHashMap<>());
     private final Map<ObjectiveCriteria, Integer> criterionObjectiveCounts = new HashMap<>();
+    private int statObjectiveCount;
 
     public CraftScoreboardManager(MinecraftServer minecraftserver, net.minecraft.world.scores.Scoreboard scoreboardServer) {
         this.mainScoreboard = new CraftScoreboard(scoreboardServer);
@@ -135,12 +136,7 @@ public final class CraftScoreboardManager implements ScoreboardManager {
     }
 
     public boolean hasStatObjectives() {
-        for (ObjectiveCriteria criteria : this.criterionObjectiveCounts.keySet()) {
-            if (criteria instanceof net.minecraft.stats.Stat<?>) {
-                return true;
-            }
-        }
-        return false;
+        return this.statObjectiveCount > 0;
     }
 
     public void onObjectiveAdded(Scoreboard scoreboard, Objective objective) {
@@ -167,11 +163,20 @@ public final class CraftScoreboardManager implements ScoreboardManager {
     }
 
     private void incrementObjectiveCriteria(ObjectiveCriteria criteria, int delta) {
-        int updated = this.criterionObjectiveCounts.getOrDefault(criteria, 0) + delta;
+        int previous = this.criterionObjectiveCounts.getOrDefault(criteria, 0);
+        int updated = previous + delta;
         if (updated <= 0) {
             this.criterionObjectiveCounts.remove(criteria);
         } else {
             this.criterionObjectiveCounts.put(criteria, updated);
         }
+
+        if (criteria instanceof net.minecraft.stats.Stat<?>) {
+            if (previous <= 0 && updated > 0) {
+                ++this.statObjectiveCount;
+            } else if (previous > 0 && updated <= 0) {
+                --this.statObjectiveCount;
+            }
+        }
     }
 }
