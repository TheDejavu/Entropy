index 0000000000000000000000000000000000000000..d2cfdf4ba70390f127c74c32ee1e0f434fc8b6c5
--- /dev/null
+++ b/src/main/java/xyz/fragmentmc/entropy/explosion/ExplosionProofItems.java
@@ -0,0 +1,25 @@
+package xyz.fragmentmc.entropy.explosion;
+
+import it.unimi.dsi.fastutil.objects.ObjectOpenHashSet;
+import net.minecraft.world.entity.item.ItemEntity;
+import org.bukkit.Material;
+import xyz.fragmentmc.entropy.EntropyConfig;
+import xyz.fragmentmc.entropy.util.ConfigUtil;
+
+public class ExplosionProofItems {
+    private static ObjectOpenHashSet<Material> explosionProofItems = new ObjectOpenHashSet<>();
+    private static boolean explodeNone = false;
+    public static boolean explodeAll = true;
+
+    public static boolean shouldExplodeItem(ItemEntity item) {
+        if (explodeAll) return true;
+        if (explodeNone) return true;
+        return !explosionProofItems.contains(item.getItem().getBukkitStack().getType());
+    }
+
+    public static void loadFromConfig() {
+        explodeAll = !EntropyConfig.explosionProofItems || EntropyConfig.explosionProofList.size() == 0;
+        explodeNone = EntropyConfig.explosionProofList.contains("*");
+        explosionProofItems = ConfigUtil.materialsFromNames(EntropyConfig.explosionProofList);
+    }
+}
diff --git a/src/main/java/xyz/fragmentmc/entropy/util/ConfigUtil.java b/src/main/java/xyz/fragmentmc/entropy/util/ConfigUtil.java
new file mode 100644
index 0000000000000000000000000000000000000000..4c2557231e83c505080342693cd937abab03aeb8
--- /dev/null
+++ b/src/main/java/xyz/fragmentmc/entropy/util/ConfigUtil.java
@@ -0,0 +1,19 @@
+package xyz.fragmentmc.entropy.util;
+
+import it.unimi.dsi.fastutil.objects.ObjectOpenHashSet;
+import org.bukkit.Material;
+
+import java.util.List;
+import java.util.Objects;
+
+public class ConfigUtil {
+    public static ObjectOpenHashSet<Material> materialsFromNames(List<String> names) {
+        ObjectOpenHashSet<Material> set = new ObjectOpenHashSet<>();
+        for (String s : names) {
+            if(!Objects.equals(s, "*")) {
+                set.add(Material.valueOf(s.toUpperCase()));
+            }
+        }
+        return set;
+    }
+}
