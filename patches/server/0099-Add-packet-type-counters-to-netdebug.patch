     }
@@ -1045,6 +1108,30 @@ public class Connection extends SimpleChannelInboundHandler<Packet<?>> {
         }
     }
 
+    private void trackSentPacketCategory(final Packet<?> packet) {
+        if (packet instanceof ClientboundLevelChunkWithLightPacket || packet instanceof ClientboundChunksBiomesPacket || packet instanceof ClientboundForgetLevelChunkPacket) {
+            ++this.chunkPacketCount;
+        } else if (packet instanceof ClientboundAddEntityPacket || packet instanceof ClientboundRemoveEntitiesPacket) {
+            ++this.addEntityPacketCount;
+        } else if (packet instanceof ClientboundMoveEntityPacket || packet instanceof ClientboundTeleportEntityPacket || packet instanceof ClientboundRotateHeadPacket || packet instanceof ClientboundSetEntityMotionPacket) {
+            ++this.movePacketCount;
+        } else if (packet instanceof ClientboundSetEntityDataPacket) {
+            ++this.metadataPacketCount;
+        } else if (packet instanceof ClientboundSetEquipmentPacket) {
+            ++this.equipmentPacketCount;
+        } else if (packet instanceof ClientboundPlayerInfoUpdatePacket || packet instanceof ClientboundPlayerInfoRemovePacket) {
+            ++this.playerInfoPacketCount;
+        } else if (packet instanceof ClientboundSoundPacket || packet instanceof ClientboundSoundEntityPacket || packet instanceof ClientboundStopSoundPacket) {
+            ++this.soundPacketCount;
+        } else if (packet instanceof ClientboundLevelParticlesPacket) {
+            ++this.particlePacketCount;
+        } else if (packet instanceof net.minecraft.network.protocol.common.ClientboundKeepAlivePacket) {
+            ++this.keepAlivePacketCount;
+        } else {
+            ++this.otherPacketCount;
+        }
+    }
+
