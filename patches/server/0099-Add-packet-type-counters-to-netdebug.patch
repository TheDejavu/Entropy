     private void sendPacket(Packet<?> packet, @Nullable PacketSendListener callbacks, boolean flush) {
         ++this.sentPackets;
         this.immediatePacketCount.incrementAndGet();
+        this.trackSentPacketCategory(packet);
         if (this.channel.eventLoop().inEventLoop()) {
             this.doSendPacket(packet, callbacks, flush);
         } else {
@@ -1011,6 +1034,46 @@ public class Connection extends SimpleChannelInboundHandler<Packet<?>> {
         return this.flushCallCount.get();
     }
 
+    public long getChunkPacketCount() {
