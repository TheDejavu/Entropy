diff --git a/src/main/java/dev/orhidea/starforge/HotspotAsyncManager.java b/src/main/java/dev/orhidea/starforge/HotspotAsyncManager.java
new file mode 100644
index 0000000000000000000000000000000000000000..20b9eb7eeb366ae14a1ad26f989fde04b36f4e2e
--- /dev/null
+++ b/src/main/java/dev/orhidea/starforge/HotspotAsyncManager.java
@@ -0,0 +1,155 @@
+package dev.orhidea.starforge;
+
+import io.papermc.paper.util.MCUtil;
+import net.minecraft.server.MinecraftServer;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.server.level.ServerPlayer;
+import net.minecraft.util.Mth;
+
+import java.util.ArrayList;
+import java.util.HashMap;
+import java.util.List;
+import java.util.UUID;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ConcurrentHashMap;
+import java.util.concurrent.atomic.AtomicBoolean;
+import java.util.concurrent.atomic.AtomicReference;
+
+public final class HotspotAsyncManager {
+    public static final HotspotAsyncManager Instance = new HotspotAsyncManager();
+
+    private static final WorldState EMPTY_WORLD_STATE = new WorldState();
+    private final ConcurrentHashMap<String, WorldState> worldStates = new ConcurrentHashMap<>();
+
+    private HotspotAsyncManager() {
+    }
+
+    public void schedule(ServerLevel level) {
+        if (!EntropyConfig.hotspotEnabled || !EntropyConfig.hotspotAsyncComputation) {
+            return;
+        }
+
+        WorldState state = this.worldStates.computeIfAbsent(level.dimension().location().toString(), ignored -> new WorldState());
+        int currentTick = MinecraftServer.currentTick;
+        if (state.lastScheduledTick == currentTick) {
+            return;
+        }
+        state.lastScheduledTick = currentTick;
+
+        if (!state.running.compareAndSet(false, true)) {
+            return;
+        }
+
+        List<ServerPlayer> players = level.players();
+        if (players.isEmpty()) {
+            state.result.set(WorldResult.EMPTY);
+            state.running.set(false);
+            return;
+        }
+
+        PlayerSnapshot[] snapshots = new PlayerSnapshot[players.size()];
+        for (int i = 0, len = players.size(); i < len; ++i) {
+            ServerPlayer player = players.get(i);
+            snapshots[i] = new PlayerSnapshot(
+                player.getUUID(),
+                player.getX(),
+                player.getZ(),
+                EntropyUserManager.Instance.isHotspotActive(player)
+            );
+        }
+
+        double radius = EntropyConfig.hotspotRadius;
+        int enableThreshold = EntropyConfig.hotspotEnableThreshold;
+        int disableThreshold = EntropyConfig.hotspotDisableThreshold;
+        int sourceTick = currentTick;
+        String worldKey = level.dimension().location().toString();
+
+        CompletableFuture
+            .supplyAsync(() -> computeWorldResult(snapshots, radius, enableThreshold, disableThreshold, sourceTick), MCUtil.asyncExecutor)
+            .whenComplete((result, throwable) -> {
+                if (throwable == null && result != null) {
+                    state.result.set(result);
+                } else if (throwable != null) {
+                    MinecraftServer.LOGGER.warn("Failed to compute hotspot state asynchronously for {}", worldKey, throwable);
+                }
+                state.running.set(false);
+            });
+    }
+
+    public Boolean getHotspotState(ServerLevel level, UUID playerId) {
+        WorldResult result = this.getWorldState(level).result.get();
+        if (result.tick < 0) {
+            return null;
+        }
+        return result.hotspotStates.get(playerId);
+    }
+
+    public boolean hasFreshResult(ServerLevel level) {
+        return this.getWorldState(level).result.get().tick >= 0;
+    }
+
+    private WorldState getWorldState(ServerLevel level) {
+        return this.worldStates.getOrDefault(level.dimension().location().toString(), EMPTY_WORLD_STATE);
+    }
+
+    private static WorldResult computeWorldResult(PlayerSnapshot[] players, double radius, int enableThreshold, int disableThreshold, int tick) {
+        double radiusSquared = radius * radius;
+        int cellSize = Math.max(1, Mth.floor(radius));
+        HashMap<Long, ArrayList<Integer>> cells = new HashMap<>();
+
+        for (int i = 0, len = players.length; i < len; ++i) {
+            PlayerSnapshot player = players[i];
+            long cellKey = getCellKey(Mth.floor(player.x / cellSize), Mth.floor(player.z / cellSize));
+            cells.computeIfAbsent(cellKey, ignored -> new ArrayList<>()).add(i);
+        }
+
+        HashMap<UUID, Boolean> hotspotStates = new HashMap<>(players.length);
+        for (int i = 0, len = players.length; i < len; ++i) {
+            PlayerSnapshot player = players[i];
+            int requiredPlayers = player.hotspotActive ? disableThreshold : enableThreshold;
+            int nearbyPlayers = 0;
+            int cellX = Mth.floor(player.x / cellSize);
+            int cellZ = Mth.floor(player.z / cellSize);
+
+            outer:
+            for (int searchX = cellX - 1; searchX <= cellX + 1; ++searchX) {
+                for (int searchZ = cellZ - 1; searchZ <= cellZ + 1; ++searchZ) {
+                    ArrayList<Integer> cell = cells.get(getCellKey(searchX, searchZ));
+                    if (cell == null) {
+                        continue;
+                    }
+
+                    for (int index : cell) {
+                        PlayerSnapshot other = players[index];
+                        double deltaX = player.x - other.x;
+                        double deltaZ = player.z - other.z;
+                        if (deltaX * deltaX + deltaZ * deltaZ <= radiusSquared && ++nearbyPlayers >= requiredPlayers) {
+                            break outer;
+                        }
+                    }
+                }
+            }
+
+            hotspotStates.put(player.uuid, player.hotspotActive ? nearbyPlayers >= disableThreshold : nearbyPlayers >= enableThreshold);
+        }
+
+        return new WorldResult(tick, hotspotStates);
+    }
+
+    private static long getCellKey(int x, int z) {
+        return ((long) z << 32) | (x & 0xFFFFFFFFL);
+    }
+
+    private record PlayerSnapshot(UUID uuid, double x, double z, boolean hotspotActive) {
+    }
+
+    private static final class WorldState {
+        private final AtomicBoolean running = new AtomicBoolean(false);
+        private final AtomicReference<WorldResult> result = new AtomicReference<>(WorldResult.EMPTY);
+        private volatile int lastScheduledTick = Integer.MIN_VALUE;
+    }
+
+    private record WorldResult(int tick, HashMap<UUID, Boolean> hotspotStates) {
+        private static final WorldResult EMPTY = new WorldResult(-1, new HashMap<>());
+    }
+}
