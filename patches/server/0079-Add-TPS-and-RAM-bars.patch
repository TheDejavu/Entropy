index 0000000000000000000000000000000000000000..67ee8167e51c06328c9a4a736a9f868ccf9972a6
--- /dev/null
+++ b/src/main/java/dev/orhidea/starforge/command/RamBarCommand.java
@@ -0,0 +1,41 @@
+package dev.orhidea.starforge.command;
+
+import com.mojang.brigadier.CommandDispatcher;
+import dev.orhidea.starforge.EntropyConfig;
+import dev.orhidea.starforge.task.RamBarTask;
+import io.papermc.paper.adventure.PaperAdventure;
+import net.kyori.adventure.text.Component;
+import net.kyori.adventure.text.format.NamedTextColor;
+import net.kyori.adventure.text.minimessage.MiniMessage;
+import net.kyori.adventure.text.minimessage.tag.resolver.Placeholder;
+import net.minecraft.commands.CommandSourceStack;
+import net.minecraft.commands.Commands;
+import net.minecraft.commands.arguments.EntityArgument;
+import net.minecraft.server.level.ServerPlayer;
+
+import java.util.Collection;
+import java.util.Collections;
+
+public final class RamBarCommand {
+    public static void register(CommandDispatcher<CommandSourceStack> dispatcher) {
+        dispatcher.register(Commands.literal("rambar")
+                .requires(listener -> listener.hasPermission(2, "starforge.command.rambar"))
+                .executes(context -> execute(context.getSource(), Collections.singleton(context.getSource().getPlayerOrException())))
+                .then(Commands.argument("targets", EntityArgument.players())
+                        .requires(listener -> listener.hasPermission(2, "starforge.command.rambar.other"))
+                        .executes(context -> execute(context.getSource(), EntityArgument.getPlayers(context, "targets")))));
+    }
+
+    private static int execute(CommandSourceStack sender, Collection<ServerPlayer> targets) {
+        for (ServerPlayer player : targets) {
+            boolean enabled = RamBarTask.instance().togglePlayer(player.getBukkitEntity());
+            player.ramBar(enabled);
+            Component output = MiniMessage.miniMessage().deserialize(EntropyConfig.rambarCommandOutput,
+                    Placeholder.component("onoff", Component.translatable(enabled ? "options.on" : "options.off")
+                            .color(enabled ? NamedTextColor.GREEN : NamedTextColor.RED)),
+                    Placeholder.parsed("target", player.getGameProfile().getName()));
+            sender.sendSuccess(() -> PaperAdventure.asVanilla(output), false);
+        }
+        return targets.size();
+    }
+}
