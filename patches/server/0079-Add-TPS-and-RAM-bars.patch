+++ b/src/main/java/dev/orhidea/starforge/task/TPSBarTask.java
@@ -0,0 +1,120 @@
+package dev.orhidea.starforge.task;
+
+import dev.orhidea.starforge.EntropyConfig;
+import net.kyori.adventure.bossbar.BossBar;
+import net.kyori.adventure.text.Component;
+import net.kyori.adventure.text.minimessage.MiniMessage;
+import net.kyori.adventure.text.minimessage.tag.resolver.Placeholder;
+import org.bukkit.Bukkit;
+import org.bukkit.entity.Player;
+
+public final class TPSBarTask extends BossBarTask {
+    private static TPSBarTask instance;
+    private double tps = 20.0D;
+    private double mspt = 0.0D;
+    private int tick;
+
+    public static TPSBarTask instance() {
+        if (instance == null) {
+            instance = new TPSBarTask();
+        }
+        return instance;
+    }
+
+    @Override
+    BossBar createBossBar() {
+        return BossBar.bossBar(Component.empty(), 0.0F, this.getBossBarColor(), EntropyConfig.commandTPSBarProgressOverlay);
+    }
+
+    @Override
+    void updateBossBar(BossBar bossbar, Player player) {
+        bossbar.progress(this.getBossBarProgress(player));
+        bossbar.color(this.getBossBarColor(player));
+        bossbar.name(MiniMessage.miniMessage().deserialize(EntropyConfig.commandTPSBarTitle,
+                Placeholder.component("tps", this.getTPSColor()),
+                Placeholder.component("mspt", this.getMSPTColor()),
+                Placeholder.component("ping", this.getPingColor(player.getPing()))));
+    }
+
+    @Override
+    public void run() {
+        if (++this.tick < EntropyConfig.commandTPSBarTickInterval) {
+            return;
+        }
+        this.tick = 0;
+        this.tps = Math.max(Math.min(Bukkit.getTPS()[0], 20.0D), 0.0D);
+        this.mspt = Bukkit.getAverageTickTime();
+        super.run();
+    }
+
+    private float getBossBarProgress(Player player) {
+        if (EntropyConfig.commandTPSBarProgressFillMode == FillMode.MSPT) {
+            return Math.max(Math.min((float) this.mspt / 50.0F, 1.0F), 0.0F);
+        }
+        if (EntropyConfig.commandTPSBarProgressFillMode == FillMode.PING) {
+            return Math.max(Math.min((float) player.getPing() / 200.0F, 1.0F), 0.0F);
+        }
+        return Math.max(Math.min((float) this.tps / 20.0F, 1.0F), 0.0F);
+    }
+
+    private BossBar.Color getBossBarColor(Player player) {
+        if (this.isGood(EntropyConfig.commandTPSBarProgressFillMode, player.getPing())) {
+            return EntropyConfig.commandTPSBarProgressColorGood;
+        }
+        if (this.isMedium(EntropyConfig.commandTPSBarProgressFillMode, player.getPing())) {
+            return EntropyConfig.commandTPSBarProgressColorMedium;
+        }
+        return EntropyConfig.commandTPSBarProgressColorLow;
+    }
+
+    private boolean isGood(FillMode mode) {
+        return this.isGood(mode, 0);
+    }
+
+    private boolean isGood(FillMode mode, int ping) {
+        return switch (mode) {
+            case MSPT -> this.mspt < 40.0D;
+            case TPS -> this.tps >= 19.0D;
+            case PING -> ping < 100;
+        };
+    }
+
+    private boolean isMedium(FillMode mode) {
+        return this.isMedium(mode, 0);
+    }
+
+    private boolean isMedium(FillMode mode, int ping) {
+        return switch (mode) {
+            case MSPT -> this.mspt < 50.0D;
+            case TPS -> this.tps >= 15.0D;
+            case PING -> ping < 200;
+        };
+    }
+
+    private Component getTPSColor() {
+        String color = this.isGood(FillMode.TPS) ? EntropyConfig.commandTPSBarTextColorGood
+                : this.isMedium(FillMode.TPS) ? EntropyConfig.commandTPSBarTextColorMedium
+                : EntropyConfig.commandTPSBarTextColorLow;
+        return MiniMessage.miniMessage().deserialize(color, Placeholder.parsed("text", String.format("%.2f", this.tps)));
+    }
+
+    private Component getMSPTColor() {
+        String color = this.isGood(FillMode.MSPT) ? EntropyConfig.commandTPSBarTextColorGood
+                : this.isMedium(FillMode.MSPT) ? EntropyConfig.commandTPSBarTextColorMedium
+                : EntropyConfig.commandTPSBarTextColorLow;
+        return MiniMessage.miniMessage().deserialize(color, Placeholder.parsed("text", String.format("%.2f", this.mspt)));
+    }
+
+    private Component getPingColor(int ping) {
+        String color = this.isGood(FillMode.PING, ping) ? EntropyConfig.commandTPSBarTextColorGood
+                : this.isMedium(FillMode.PING, ping) ? EntropyConfig.commandTPSBarTextColorMedium
+                : EntropyConfig.commandTPSBarTextColorLow;
+        return MiniMessage.miniMessage().deserialize(color, Placeholder.parsed("text", Integer.toString(ping)));
+    }
+
+    public enum FillMode {
+        TPS,
+        MSPT,
+        PING
+    }
+}
