+    public boolean shouldThrottleHotspotParticle(Player player, ClientboundLevelParticlesPacket packet, int interval) {
+        if (interval <= 1 || !this.isHotspotActive(player)) {
+            return false;
+        }
+
+        long positionHash = ((long) Math.floor(packet.getX()) * 73428767L)
+            ^ ((long) Math.floor(packet.getY()) * 912931L)
+            ^ ((long) Math.floor(packet.getZ()) * 3644798167L);
+        long discriminator = net.minecraft.server.MinecraftServer.currentTick + player.getId() + positionHash;
+        return Math.floorMod(discriminator, interval) != 0;
+    }
+
