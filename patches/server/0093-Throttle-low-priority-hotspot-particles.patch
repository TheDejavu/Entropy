+    private boolean shouldThrottleLowPriorityHotspotParticle(Player player, net.minecraft.network.protocol.game.ClientboundLevelParticlesPacket packet) {
+        if (EntropyConfig.hotspotLowPriorityParticleInterval <= 1) {
+            return false;
+        }
+        if (!this.isLowPriorityHotspotParticle(packet.getParticle().getType())) {
+            return false;
+        }
+
+        return EntropyUserManager.Instance.shouldThrottleHotspotParticle(player, packet, EntropyConfig.hotspotLowPriorityParticleInterval);
+    }
+
+    private boolean isLowPriorityHotspotParticle(ParticleType<?> particleType) {
+        if (LOW_PRIORITY_HOTSPOT_PARTICLES.isEmpty()) {
+            this.prefillLowPriorityHotspotParticles();
+        }
+
+        return LOW_PRIORITY_HOTSPOT_PARTICLES.contains(particleType);
+    }
+
+    private void prefillLowPriorityHotspotParticles() {
+        for (java.util.Map.Entry<net.minecraft.resources.ResourceKey<ParticleType<?>>, ParticleType<?>> entry : BuiltInRegistries.PARTICLE_TYPE.entrySet()) {
+            String path = entry.getKey().location().getPath();
+            if (path.contains("ambient") || path.contains("bubble") || path.contains("poof") || path.contains("smoke") || path.contains("splash")) {
+                LOW_PRIORITY_HOTSPOT_PARTICLES.add(entry.getValue());
+            }
+        }
+    }
+
