         this.invertedVisibilityEntities.put(entity.getUniqueId(), invertedPlugins);
+        if (this.invertedVisibilityEntities.size() == 1) {
+            activeVisibilityInversionPlayers.incrementAndGet();
+        }
 
         return true;
     }
@@ -1978,6 +1983,8 @@ public class CraftPlayer extends CraftHumanEntity implements Player {
 
         if (this.invertedVisibilityEntities.remove(entity.getUniqueId()) == null) {
             this.untrackAndHideEntity(entity);
+        } else if (this.invertedVisibilityEntities.isEmpty()) {
+            activeVisibilityInversionPlayers.decrementAndGet();
         }
     }
 
@@ -2027,6 +2034,9 @@ public class CraftPlayer extends CraftHumanEntity implements Player {
             return false; // Some other plugins still want the entity inverted
         }
         this.invertedVisibilityEntities.remove(entity.getUniqueId());
+        if (this.invertedVisibilityEntities.isEmpty()) {
+            activeVisibilityInversionPlayers.decrementAndGet();
+        }
 
         return true;
     }
@@ -2102,6 +2112,8 @@ public class CraftPlayer extends CraftHumanEntity implements Player {
 
         if (this.invertedVisibilityEntities.remove(entity.getUniqueId()) == null) {
             this.trackAndShowEntity(entity);
+        } else if (this.invertedVisibilityEntities.isEmpty()) {
+            activeVisibilityInversionPlayers.decrementAndGet();
         }
     }
     // Paper start
@@ -2134,7 +2146,16 @@ public class CraftPlayer extends CraftHumanEntity implements Player {
     // Paper end
 
     public void onEntityRemove(Entity entity) {
-        this.invertedVisibilityEntities.remove(entity.getUUID());
+        if (this.invertedVisibilityEntities.remove(entity.getUUID()) != null && this.invertedVisibilityEntities.isEmpty()) {
+            activeVisibilityInversionPlayers.decrementAndGet();
+        }
+    }
+
+    public void clearVisibilityInversions() {
+        if (!this.invertedVisibilityEntities.isEmpty()) {
+            this.invertedVisibilityEntities.clear();
+            activeVisibilityInversionPlayers.decrementAndGet();
+        }
     }
 
     @Override
@@ -2155,6 +2176,10 @@ public class CraftPlayer extends CraftHumanEntity implements Player {
         return !this.invertedVisibilityEntities.isEmpty();
     }
 
+    public static boolean hasAnyVisibilityInversions() {
+        return activeVisibilityInversionPlayers.get() != 0;
+    }
+
     public boolean canSee(UUID uuid) {
         org.bukkit.entity.Entity entity = this.getServer().getPlayer(uuid);
         if (entity == null) {
