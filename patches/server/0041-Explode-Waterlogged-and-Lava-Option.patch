 // CraftBukkit end
 
 public class Explosion {
@@ -152,6 +155,13 @@ public class Explosion {
         int i;
         int j;
 
+        // Entropy start - explosion submerged check
+        boolean doBlockBreakCheck = true;
+        if(EntropyConfig.explosionWaterCheck && this.source != null) {
+            BlockState blockState = this.level.getBlockState(this.source.blockPosition);
+            doBlockBreakCheck=!(EntropyConfig.explodeLava ? blockState.getMaterial().equals(Material.WATER) : blockState.getMaterial().isLiquid());
+        }
+        if(doBlockBreakCheck) // Entropy end
         for (int k = 0; k < 16; ++k) {
             for (i = 0; i < 16; ++i) {
                 for (j = 0; j < 16; ++j) {
@@ -185,6 +195,15 @@ public class Explosion {
                                 f -= ((Float) optional.get() + 0.3F) * 0.3F;
                             }
 
+                            // Entropy start - explode waterlogged blocks and lava
+                            if (EntropyConfig.explodeWaterloggedBlocks && !iblockdata.getFluidState().isEmpty() && !iblockdata.getMaterial().isLiquid()) {
+                                set.add(blockposition);
+                            }
+                            if (EntropyConfig.explodeLava && iblockdata.getMaterial() == Material.LAVA) {
+                                set.add(blockposition);
+                            }
+                            // Entropy end
+
                             if (f > 0.0F && this.damageCalculator.shouldBlockExplode(this, this.level, blockposition, iblockdata, f)) {
                                 set.add(blockposition);
                                 // Paper start - prevent headless pistons from forming
diff --git a/src/main/java/xyz/fragmentmc/entropy/EntropyConfig.java b/src/main/java/xyz/fragmentmc/entropy/EntropyConfig.java
index e841426dd908dcd97a65a2a2f48b3d127088df1f..e48584a178242af1743b17d80e65b9f1eac790a7 100644
--- a/src/main/java/xyz/fragmentmc/entropy/EntropyConfig.java
+++ b/src/main/java/xyz/fragmentmc/entropy/EntropyConfig.java
@@ -229,11 +229,22 @@ public class EntropyConfig {
 
     public static boolean disableWaterPushingTNT;
     public static boolean disableTNTSpread;
+    public static boolean explosionWaterCheck;
+    public static boolean explodeWaterloggedBlocks;
+    public static boolean explodeLava;
     private static void cannoningConfiguration() {
         disableWaterPushingTNT = getBoolean("entropy.cannons.disable-water-pushing-tnt", true,
                 "Disable TNT getting pushed by water (aka. Waterflow).");
         disableTNTSpread = getBoolean("entropy.cannons.disable-tnt-spread", true,
                 "Disable the random velocity TNT gets when ignited.");
+        explosionWaterCheck= getBoolean("entropy.cannons.explosion-submerged-check", true,
+                "Disable block breaking checks when tnt explodes while submerged.");
+        explodeWaterloggedBlocks= getBoolean("entropy.cannons.explode-waterlogged-blocks", true,
+                "Waterlogged blocks will be destroyed by explosions.",
+                "This can be used to prevent unraidable bases.");
+        explodeLava= getBoolean("entropy.cannons.explode-lava", false,
+                "Lava will be destroyed by explosions.",
+                "Use this for non-regen servers.");
 
         setComment("entropy.cannons", "Settings related to cannoning");
     }
