From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Dejavu <thedeejayv1@gmail.com>
Date: Mon, 9 Mar 2026 11:57:04 +0200
Subject: [PATCH] Reduce join and tracker visibility churn


diff --git a/src/main/java/net/minecraft/server/level/ChunkMap.java b/src/main/java/net/minecraft/server/level/ChunkMap.java
index 4f860296e526a70bcc9b8bfd489526154bbcf4dd..7c0b8104a6ab25e51dbe7a66a7953bb73ff8340e 100644
--- a/src/main/java/net/minecraft/server/level/ChunkMap.java
+++ b/src/main/java/net/minecraft/server/level/ChunkMap.java
@@ -1526,7 +1526,7 @@ public class ChunkMap extends ChunkStorage implements ChunkHolder.PlayerProvider
                 double d0 = Math.min(visibleRange, i * 16);
                 double d1 = vec3d_dx * vec3d_dx + vec3d_dz * vec3d_dz; // Paper
                 double d2 = d0 * d0;
-                boolean flag = d1 <= d2 && this.entity.broadcastToPlayer(player) && ChunkMap.this.isChunkTracked(player, this.cachedChunkX, this.cachedChunkZ);
+                boolean flag = d1 <= d2 && ChunkMap.this.isChunkTracked(player, this.cachedChunkX, this.cachedChunkZ) && this.entity.broadcastToPlayer(player);
                 // Paper start - Configurable entity tracking range by Y
                 if (flag && level.paperConfig().entities.trackingRangeY.enabled) {
                     double rangeY = level.paperConfig().entities.trackingRangeY.get(this.entity, -1);
diff --git a/src/main/java/net/minecraft/server/players/PlayerList.java b/src/main/java/net/minecraft/server/players/PlayerList.java
index f57eeafe3e50fa3ac2517d5d9a0bfa4be5b2cc80..0ddfa7d8f71929b3e03424407b336b0810f73b9b 100644
--- a/src/main/java/net/minecraft/server/players/PlayerList.java
+++ b/src/main/java/net/minecraft/server/players/PlayerList.java
@@ -431,32 +431,40 @@ public abstract class PlayerList {
         // CraftBukkit end
 
         // CraftBukkit start - sendAll above replaced with this loop
-        ClientboundPlayerInfoUpdatePacket packet = ClientboundPlayerInfoUpdatePacket.createPlayerInitializing(List.of(player)); // Paper - Add Listing API for Player
+        final ClientboundPlayerInfoUpdatePacket packet = ClientboundPlayerInfoUpdatePacket.createPlayerInitializing(List.of(player)); // Paper - Add Listing API for Player
+        ClientboundPlayerInfoUpdatePacket unlistedPacket = null;
 
         final ServerPlayer[] currentPlayers = this.getPlayersArray();
-        final List<ServerPlayer> onlinePlayers = Lists.newArrayListWithExpectedSize(Math.max(0, currentPlayers.length - 1)); // Paper - Use single player info update packet on join
+        List<ServerPlayer> onlinePlayers = null; // Paper - Use single player info update packet on join
         for (ServerPlayer entityplayer1 : currentPlayers) {
+            final CraftPlayer otherBukkit = entityplayer1.getBukkitEntity();
 
-            if (entityplayer1.getBukkitEntity().canSee(bukkitPlayer)) {
+            if (otherBukkit.canSee(bukkitPlayer)) {
                 // Paper start - Add Listing API for Player
-                if (entityplayer1.getBukkitEntity().isListed(bukkitPlayer)) {
+                if (otherBukkit.isListed(bukkitPlayer)) {
                 // Paper end - Add Listing API for Player
                 entityplayer1.connection.send(packet);
                 // Paper start - Add Listing API for Player
                 } else {
-                    entityplayer1.connection.send(ClientboundPlayerInfoUpdatePacket.createSinglePlayerInitializing(player, false));
+                    if (unlistedPacket == null) {
+                        unlistedPacket = ClientboundPlayerInfoUpdatePacket.createSinglePlayerInitializing(player, false);
+                    }
+                    entityplayer1.connection.send(unlistedPacket);
                 }
                 // Paper end - Add Listing API for Player
             }
 
-            if (entityplayer1 == player || !bukkitPlayer.canSee(entityplayer1.getBukkitEntity())) { // Paper - Use single player info update packet on join; Don't include joining player
+            if (entityplayer1 == player || !bukkitPlayer.canSee(otherBukkit)) { // Paper - Use single player info update packet on join; Don't include joining player
                 continue;
             }
 
+            if (onlinePlayers == null) {
+                onlinePlayers = Lists.newArrayListWithExpectedSize(Math.max(0, currentPlayers.length - 1));
+            }
             onlinePlayers.add(entityplayer1); // Paper - Use single player info update packet on join
         }
         // Paper start - Use single player info update packet on join
-        if (!onlinePlayers.isEmpty()) {
+        if (onlinePlayers != null && !onlinePlayers.isEmpty()) {
             player.connection.send(ClientboundPlayerInfoUpdatePacket.createPlayerInitializing(onlinePlayers, player)); // Paper - Add Listing API for Player
         }
         // Paper end - Use single player info update packet on join
@@ -1446,15 +1454,17 @@ public abstract class PlayerList {
     }
 
     public void sendAllPlayerInfo(ServerPlayer player) {
+        final CraftPlayer bukkitPlayer = player.getBukkitEntity();
         player.inventoryMenu.sendAllDataToRemote();
         // entityplayer.resetSentInfo();
-        player.getBukkitEntity().updateScaledHealth(); // CraftBukkit - Update scaled health on respawn and worldchange
+        bukkitPlayer.updateScaledHealth(); // CraftBukkit - Update scaled health on respawn and worldchange
         player.getEntityData().refresh(player); // CraftBukkkit - SPIGOT-7218: sync metadata
         player.connection.send(new ClientboundSetCarriedItemPacket(player.getInventory().selected));
         // CraftBukkit start - from GameRules
-        int i = player.level().getGameRules().getBoolean(GameRules.RULE_REDUCEDDEBUGINFO) ? 22 : 23;
+        final GameRules gameRules = player.level().getGameRules();
+        int i = gameRules.getBoolean(GameRules.RULE_REDUCEDDEBUGINFO) ? 22 : 23;
         player.connection.send(new ClientboundEntityEventPacket(player, (byte) i));
-        float immediateRespawn = player.level().getGameRules().getBoolean(GameRules.RULE_DO_IMMEDIATE_RESPAWN) ? 1.0F: 0.0F;
+        float immediateRespawn = gameRules.getBoolean(GameRules.RULE_DO_IMMEDIATE_RESPAWN) ? 1.0F: 0.0F;
         player.connection.send(new ClientboundGameEventPacket(ClientboundGameEventPacket.IMMEDIATE_RESPAWN, immediateRespawn));
         // CraftBukkit end
     }
