+    private boolean shouldCoalesceMovementFlush(final Packet<?> packet) {
+        return packet instanceof ClientboundMoveEntityPacket
+            || packet instanceof ClientboundTeleportEntityPacket
+            || packet instanceof ClientboundRotateHeadPacket
+            || packet instanceof ClientboundSetEntityMotionPacket;
+    }
+
+    private void scheduleDeferredMovementFlush() {
+        if (!this.movementFlushQueued.compareAndSet(false, true)) {
+            return;
+        }
+
+        ++this.coalescedMovementFlushCount;
+        this.flushCallCount.incrementAndGet();
+        this.channel.eventLoop().execute(() -> {
+            this.movementFlushQueued.set(false);
+            if (this.channel != null && this.channel.isOpen()) {
+                this.channel.flush();
+            }
+        });
+    }
+
