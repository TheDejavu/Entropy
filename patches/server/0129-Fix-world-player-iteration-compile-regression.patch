Subject: [PATCH] Fix world player iteration compile regression


diff --git a/src/main/java/net/minecraft/server/level/ServerLevel.java b/src/main/java/net/minecraft/server/level/ServerLevel.java
index 2123d8e47816c4f184e3dc20d4adf90736da89cf..70b9635f3eb0ae5967ad7ee0c036bbe3caeebeca 100644
--- a/src/main/java/net/minecraft/server/level/ServerLevel.java
+++ b/src/main/java/net/minecraft/server/level/ServerLevel.java
@@ -1193,8 +1193,8 @@ public class ServerLevel extends Level implements WorldGenLevel {
                 }
 
                 final ServerPlayer[] players = this.playersView;
-                for (int i = 0, len = players.length; i < len; ++i) {
-                    players[i].displayClientMessage(ichatmutablecomponent, true);
+                for (int playerIdx = 0, len = players.length; playerIdx < len; ++playerIdx) {
+                    players[playerIdx].displayClientMessage(ichatmutablecomponent, true);
                 }
 
             }
