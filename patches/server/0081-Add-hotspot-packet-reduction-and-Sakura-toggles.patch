diff --git a/src/main/java/dev/orhidea/starforge/EntropyUserManager.java b/src/main/java/dev/orhidea/starforge/EntropyUserManager.java
index e510f52af3ffd965903e1c109059ad8db8da8aad..a0861b51800bcc207cdbc3da5d222eb6717ff8b6 100644
--- a/src/main/java/dev/orhidea/starforge/EntropyUserManager.java
+++ b/src/main/java/dev/orhidea/starforge/EntropyUserManager.java
@@ -1,5 +1,6 @@
 package dev.orhidea.starforge;
 
+import net.minecraft.server.level.ServerPlayer;
 import net.minecraft.world.entity.player.Player;
 
 import java.util.HashMap;
@@ -17,13 +18,45 @@ public class EntropyUserManager {
     public FpsData getFpsData(Player player) {
         FpsData data = PlayerFpsData.get(player.getUUID());
         if (data == null) {
-            FpsData nd = new FpsData(false, false, false, false, false, false, false);
+            FpsData nd = new FpsData();
             PlayerFpsData.put(player.getUUID(), nd);
             return nd;
         }
         return data;
     }
 
+    public void updateHotspot(ServerPlayer player) {
+        FpsData data = this.getFpsData(player);
+        if (!EntropyConfig.hotspotEnabled) {
+            data.clearHotspotState();
+            player.trackingRangeModifier = 1.0D;
+            return;
+        }
+
+        double radius = EntropyConfig.hotspotRadius;
+        double radiusSquared = radius * radius;
+        int nearbyPlayers = 0;
+        int requiredPlayers = data.HotspotActive ? EntropyConfig.hotspotDisableThreshold : EntropyConfig.hotspotEnableThreshold;
+
+        for (ServerPlayer other : player.serverLevel().players()) {
+            if (other.isRemoved()) {
+                continue;
+            }
+            if (player.distanceToSqr(other) <= radiusSquared && ++nearbyPlayers >= requiredPlayers) {
+                break;
+            }
+        }
+
+        boolean hotspotActive = data.HotspotActive
+            ? nearbyPlayers >= EntropyConfig.hotspotDisableThreshold
+            : nearbyPlayers >= EntropyConfig.hotspotEnableThreshold;
+
+        data.HotspotActive = hotspotActive;
+        data.HotspotParticlesHidden = hotspotActive && EntropyConfig.hotspotHideParticles;
+        data.HotspotSoundsHidden = hotspotActive && EntropyConfig.hotspotHideSounds;
+        player.trackingRangeModifier = hotspotActive ? EntropyConfig.hotspotTrackingRangeModifier : 1.0D;
+    }
+
     public static final class FpsData {
         public boolean TntHidden;
         public boolean SandHidden;
@@ -32,18 +65,14 @@ public class EntropyUserManager {
         public boolean ExplosionHidden;
         public boolean FlashHidden;
         public boolean PistonHidden;
+        public boolean HotspotActive;
+        public boolean HotspotParticlesHidden;
+        public boolean HotspotSoundsHidden;
 
-        public FpsData(
-                boolean TntHidden, boolean SandHidden, boolean AnvilHidden, boolean ConcreteHidden,
-                boolean ExplosionHidden, boolean FlashHidden, boolean PistonHidden
-        ) {
-            this.TntHidden = TntHidden;
-            this.SandHidden = SandHidden;
-            this.AnvilHidden = AnvilHidden;
-            this.ConcreteHidden = ConcreteHidden;
-            this.ExplosionHidden = ExplosionHidden;
-            this.FlashHidden = FlashHidden;
-            this.PistonHidden = PistonHidden;
+        public void clearHotspotState() {
+            this.HotspotActive = false;
+            this.HotspotParticlesHidden = false;
+            this.HotspotSoundsHidden = false;
         }
     }
 }
