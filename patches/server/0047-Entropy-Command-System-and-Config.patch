@@ -0,0 +1,47 @@
+package xyz.fragmentmc.entropy.command;
+
+import net.kyori.adventure.text.Component;
+import net.kyori.adventure.text.JoinConfiguration;
+import net.kyori.adventure.text.TextComponent;
+import net.kyori.adventure.text.format.NamedTextColor;
+import net.kyori.adventure.text.format.TextDecoration;
+import org.bukkit.command.Command;
+import org.bukkit.command.CommandSender;
+import org.jetbrains.annotations.NotNull;
+import org.w3c.dom.Text;
+
+import java.util.Arrays;
+
+public abstract class EntropyCommandBase extends Command {
+    private final EntropyCommandData commandData;
+
+    protected final TextComponent prefix = (TextComponent) Component.join(
+            JoinConfiguration.noSeparators(),
+            Component.text("Entropy >", NamedTextColor.GOLD, TextDecoration.BOLD),
+            Component.text(" ", NamedTextColor.WHITE));
+    public EntropyCommandData getCommandData() {
+        return commandData;
+    }
+
+    @Override
+    public boolean execute(@NotNull CommandSender sender, @NotNull String commandLabel, @NotNull String[] args) {
+        if (!testPermission(sender)) return true;
+        if (args.length != 1) {
+            sender.sendMessage(prefix.toBuilder().append(Component.text("Usage: " + usageMessage)).build());
+            return true;
+            }
+        return run(sender, commandLabel, args);
+    }
+
+    protected EntropyCommandBase() {
+        super("");
+        commandData = this.getClass().getAnnotation(EntropyCommandData.class);
+        this.setName(commandData.name());
+        this.setDescription(commandData.description());
+        this.setUsage(commandData.usageMessage());
+        this.setAliases(Arrays.stream(commandData.aliases()).toList());
+        this.setPermission(commandData.permission());
+    }
+
+    protected abstract boolean run(@NotNull CommandSender sender, @NotNull String commandLabel, @NotNull String[] args);
+}
diff --git a/src/main/java/xyz/fragmentmc/entropy/command/EntropyCommandData.java b/src/main/java/xyz/fragmentmc/entropy/command/EntropyCommandData.java
