+package xyz.fragmentmc.entropy.command;
+
+import net.minecraft.server.MinecraftServer;
+import org.bukkit.command.Command;
+import xyz.fragmentmc.entropy.command.commands.EntropyCommand;
+
+public class EntropyCommandLoader {
+    public static void loadCommands() {
+        load(new EntropyCommand());
+    }
+
+    private static void load(Command command) {
+        MinecraftServer.getServer().server.getCommandMap().register(command.getName(), command.getName(), command);
+    }
+}
