diff --git a/src/main/java/dev/orhidea/starforge/EntropyConfig.java b/src/main/java/dev/orhidea/starforge/EntropyConfig.java
index 877b32e343eaf60754dc4adde0b74d7db06759b0..0dd30ff72dda56ef9cf5317a351f1303b6c64f9c 100644
--- a/src/main/java/dev/orhidea/starforge/EntropyConfig.java
+++ b/src/main/java/dev/orhidea/starforge/EntropyConfig.java
@@ -220,6 +220,70 @@ public class EntropyConfig {
         setComment("starforge.optimizations", "Changes that improve cannoning performance.", "* - slight behaviour changes, should not be noticeable.");
     }
 
+    public static boolean useGameEventCache;
+    public static boolean useCustomNameOptimisation;
+    public static boolean useSupportingBlockLookupOptimisation;
+    public static boolean disableItemMergeCheckWhileMoving;
+    public static int itemMergeMovingInterval;
+    public static int itemMergeStaticInterval;
+    public static boolean cropIgnoreLightLevel;
+    public static boolean mushroomIgnoreLightLevel;
+    public static boolean stemIgnoreLightLevel;
+    public static boolean bambooSaplingIgnoreLightLevel;
+    public static boolean bambooStalkIgnoreLightLevel;
+    public static boolean sweetBerryBushIgnoreLightLevel;
+    public static boolean saplingIgnoreLightLevel;
+    public static boolean pitcherCropIgnoreLightLevel;
+    public static boolean disableTargetSelector;
+    public static boolean disableGoalSelector;
+    public static boolean disableFlapEvents;
+    private static void performance() {
+        useGameEventCache = getBoolean("starforge.performance.use-game-event-cache", true, "Cache Bukkit game event lookups to reduce repeated registry conversions.");
+        useCustomNameOptimisation = getBoolean("starforge.performance.use-custom-name-optimisation", true, "Skip URL matching when parsing legacy custom names.");
+        useSupportingBlockLookupOptimisation = getBoolean("starforge.performance.use-supporting-block-lookup-optimisation", true, "Shrink the vertical search range when checking a supporting block.");
+        disableItemMergeCheckWhileMoving = getBoolean("starforge.performance.item-merge.disable-check-while-moving", false, "Skip item merge scans while an item entity is moving.");
+        itemMergeMovingInterval = Math.max(1, getInt("starforge.performance.item-merge.moving-interval", 2, "Tick interval for merge checks on moving item entities."));
+        itemMergeStaticInterval = Math.max(1, getInt("starforge.performance.item-merge.static-interval", 40, "Tick interval for merge checks on stationary item entities."));
+        cropIgnoreLightLevel = getBoolean("starforge.performance.ignore-light-level.crop", false, "Skip crop light-level checks.");
+        mushroomIgnoreLightLevel = getBoolean("starforge.performance.ignore-light-level.mushroom", false, "Skip mushroom light-level checks.");
+        stemIgnoreLightLevel = getBoolean("starforge.performance.ignore-light-level.stem", false, "Skip melon and pumpkin stem light-level checks.");
+        bambooSaplingIgnoreLightLevel = getBoolean("starforge.performance.ignore-light-level.bamboo-sapling", false, "Skip bamboo sapling light-level checks.");
+        bambooStalkIgnoreLightLevel = getBoolean("starforge.performance.ignore-light-level.bamboo-stalk", false, "Skip bamboo stalk light-level checks.");
+        sweetBerryBushIgnoreLightLevel = getBoolean("starforge.performance.ignore-light-level.sweet-berry-bush", false, "Skip sweet berry bush light-level checks.");
+        saplingIgnoreLightLevel = getBoolean("starforge.performance.ignore-light-level.sapling", false, "Skip sapling light-level checks.");
+        pitcherCropIgnoreLightLevel = getBoolean("starforge.performance.ignore-light-level.pitcher-crop", false, "Skip pitcher crop light-level checks.");
+        disableTargetSelector = getBoolean("starforge.performance.disable-target-selector", false, "Disable mob target selector ticking.");
+        disableGoalSelector = getBoolean("starforge.performance.disable-goal-selector", false, "Disable mob goal selector ticking.");
+        disableFlapEvents = getBoolean("starforge.performance.disable-flap-game-event", false, "Disable the movement game event emitted by flapping entities.");
+
+        setComment("starforge.performance", "General-purpose performance options imported from Pluto.");
+    }
+
+    public static int entityActivationInterval;
+    public static boolean disableEntityActivation;
+    public static int blockTickingModulo;
+    public static int fluidTickingModulo;
+    public static int raidTickingModulo;
+    public static int blockEventTickingModulo;
+    public static int entityDespawnCheckModulo;
+    public static int entityPushingModulo;
+    public static int entityInsideBlockCheck;
+    public static int entityRainCheckRate;
+    private static void ticking() {
+        entityActivationInterval = Math.max(1, getInt("starforge.ticking.entity-activation.interval", 1, "Only run activation range scans every N ticks."));
+        disableEntityActivation = getBoolean("starforge.ticking.entity-activation.disable", false, "Disable activation range scans entirely.");
+        blockTickingModulo = getInt("starforge.ticking.block-ticks-modulo", 1, "How often scheduled block ticks run. Values below 1 disable block ticks.");
+        fluidTickingModulo = getInt("starforge.ticking.fluid-ticks-modulo", 1, "How often scheduled fluid ticks run. Values below 1 disable fluid ticks.");
+        raidTickingModulo = getInt("starforge.ticking.raid-ticks-modulo", 1, "How often raid logic runs. Values below 1 disable raid ticking.");
+        blockEventTickingModulo = getInt("starforge.ticking.block-event-ticks-modulo", 1, "How often block events run. Values below 1 disable block-event ticking.");
+        entityDespawnCheckModulo = getInt("starforge.ticking.entity-despawn-check-modulo", 1, "How often entity despawn checks run. Values below 1 disable despawn checks.");
+        entityPushingModulo = getInt("starforge.ticking.entity-pushing-modulo", 1, "How often living entities perform push checks. Values below 1 disable entity pushing.");
+        entityInsideBlockCheck = getInt("starforge.ticking.entity-inside-block-check-modulo", 1, "How often entities run inside-block collision checks. Values below 1 disable the check.");
+        entityRainCheckRate = Math.max(1, getInt("starforge.ticking.entity-rain-check-rate", 10, "How often entities recompute rain exposure."));
+
+        setComment("starforge.ticking", "Tick-rate controls imported from Pluto. Values below 1 disable the guarded task unless otherwise noted.");
+    }
+
     public static boolean packetLimiterTntFlow;
     public static boolean packetLimiterTntMove;
     public static boolean packetLimiterTntVelocity;
