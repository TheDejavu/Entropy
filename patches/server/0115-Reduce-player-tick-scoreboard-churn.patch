diff --git a/src/main/java/org/bukkit/craftbukkit/scoreboard/CraftScoreboardManager.java b/src/main/java/org/bukkit/craftbukkit/scoreboard/CraftScoreboardManager.java
index cc939b946196b4a980a4e726441ab278eb298274..bca30e53240fabfaeecef3d3ea101bf4a915b229 100644
--- a/src/main/java/org/bukkit/craftbukkit/scoreboard/CraftScoreboardManager.java
+++ b/src/main/java/org/bukkit/craftbukkit/scoreboard/CraftScoreboardManager.java
@@ -141,6 +141,36 @@ public final class CraftScoreboardManager implements ScoreboardManager {
         }
     }
 
+    public void incrementScoreForAllObjectives(ObjectiveCriteria criteria, ScoreHolder holder) {
+        if (this.criterionObjectiveCounts.getOrDefault(criteria, 0) <= 0) {
+            return;
+        }
+        for (CraftScoreboard scoreboard : this.scoreboards) {
+            Scoreboard board = scoreboard.board;
+            board.forAllObjectives(criteria, holder, ScoreAccess::increment);
+        }
+    }
+
+    public void addScoreForAllObjectives(ObjectiveCriteria criteria, ScoreHolder holder, int amount) {
+        if (this.criterionObjectiveCounts.getOrDefault(criteria, 0) <= 0) {
+            return;
+        }
+        for (CraftScoreboard scoreboard : this.scoreboards) {
+            Scoreboard board = scoreboard.board;
+            board.forAllObjectives(criteria, holder, scoreAccess -> scoreAccess.add(amount));
+        }
+    }
+
+    public void resetScoreForAllObjectives(ObjectiveCriteria criteria, ScoreHolder holder) {
+        if (this.criterionObjectiveCounts.getOrDefault(criteria, 0) <= 0) {
+            return;
+        }
+        for (CraftScoreboard scoreboard : this.scoreboards) {
+            Scoreboard board = scoreboard.board;
+            board.forAllObjectives(criteria, holder, ScoreAccess::reset);
+        }
+    }
+
     public boolean hasObjectivesForCriteria(ObjectiveCriteria criteria) {
         return this.criterionObjectiveCounts.getOrDefault(criteria, 0) > 0;
     }
