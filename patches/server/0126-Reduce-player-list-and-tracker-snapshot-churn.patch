+    private final class PlayerListSnapshot extends AbstractList<ServerPlayer> implements RandomAccess {
+        private ServerPlayer[] players = EMPTY_PLAYERS;
+        private int size;
+
+        @Override
+        public ServerPlayer get(int index) {
+            if (index < 0 || index >= this.size) {
+                throw new IndexOutOfBoundsException(index);
+            }
+            return this.players[index];
+        }
+
+        @Override
+        public int size() {
+            return this.size;
+        }
+
+        @Override
+        public boolean add(ServerPlayer player) {
+            this.add(this.size, player);
+            return true;
+        }
+
+        @Override
+        public void add(int index, ServerPlayer player) {
+            if (index < 0 || index > this.size) {
+                throw new IndexOutOfBoundsException(index);
+            }
+            int currentSize = this.size;
+            ServerPlayer[] currentPlayers = this.players;
+            if (currentSize == currentPlayers.length) {
+                int newSize = currentSize == 0 ? 4 : currentSize << 1;
+                currentPlayers = java.util.Arrays.copyOf(currentPlayers, newSize);
+                this.players = currentPlayers;
+            }
+            if (index != currentSize) {
+                System.arraycopy(currentPlayers, index, currentPlayers, index + 1, currentSize - index);
+            }
+            currentPlayers[index] = player;
+            this.size = currentSize + 1;
+            PlayerList.this.refreshPlayersView();
+        }
+
+        @Override
+        public ServerPlayer remove(int index) {
+            if (index < 0 || index >= this.size) {
+                throw new IndexOutOfBoundsException(index);
+            }
+            ServerPlayer[] currentPlayers = this.players;
+            ServerPlayer removed = currentPlayers[index];
+            int lastIndex = this.size - 1;
+            if (index != lastIndex) {
+                System.arraycopy(currentPlayers, index + 1, currentPlayers, index, lastIndex - index);
+            }
+            currentPlayers[lastIndex] = null;
+            this.size = lastIndex;
+            PlayerList.this.refreshPlayersView();
+            return removed;
+        }
+
+        @Override
+        public boolean remove(Object object) {
+            ServerPlayer[] currentPlayers = this.players;
+            int currentSize = this.size;
+            for (int i = 0; i < currentSize; ++i) {
+                if (currentPlayers[i] == object) {
+                    this.remove(i);
+                    return true;
+                }
+            }
+            return false;
+        }
+
+        @Override
+        public ServerPlayer set(int index, ServerPlayer player) {
+            if (index < 0 || index >= this.size) {
+                throw new IndexOutOfBoundsException(index);
+            }
+            ServerPlayer[] currentPlayers = this.players;
+            ServerPlayer previous = currentPlayers[index];
+            currentPlayers[index] = player;
+            PlayerList.this.refreshPlayersView();
+            return previous;
+        }
+
+        @Override
+        public void clear() {
+            if (this.size == 0) {
+                return;
+            }
+            java.util.Arrays.fill(this.players, 0, this.size, null);
+            this.size = 0;
+            PlayerList.this.refreshPlayersView();
+        }
+
+        @Override
+        public Iterator<ServerPlayer> iterator() {
+            final ServerPlayer[] snapshot = PlayerList.this.playersView;
+            return new Iterator<>() {
+                private int index;
+
+                @Override
+                public boolean hasNext() {
+                    return this.index < snapshot.length;
+                }
+
+                @Override
+                public ServerPlayer next() {
+                    return snapshot[this.index++];
+                }
+            };
+        }
+
+        @Override
+        public Object[] toArray() {
+            return java.util.Arrays.copyOf(PlayerList.this.playersView, PlayerList.this.playersView.length, Object[].class);
+        }
+
+        @Override
+        public <T> T[] toArray(T[] array) {
+            ServerPlayer[] snapshot = PlayerList.this.playersView;
+            int length = snapshot.length;
+            if (array.length < length) {
+                return (T[]) java.util.Arrays.copyOf(snapshot, length, array.getClass());
+            }
+            System.arraycopy(snapshot, 0, array, 0, length);
+            if (array.length > length) {
+                array[length] = null;
+            }
+            return array;
+        }
+    }
+
     private static final class PlayerInfoBucket {
