@@ -272,6 +272,13 @@ public class EntropyConfig {
     public static short spawnerMaxNearbyEntities;
     public static short spawnerRequiredPlayerRange;
     public static short spawnerSpawnRange;
+    public static boolean onlyTickItemsInHand;
+    public static boolean cacheChunkPackets;
+    public static boolean skipIdleEntitySchedulerTicks;
+    public static boolean rewriteFramedMapTracker;
+    public static boolean skipMapItemDataUpdatesWithoutCraftRenderer;
+    public static boolean dontSavePrimedTnt;
+    public static boolean dontSaveFallingBlocks;
     private static void performance() {
         useGameEventCache = getBoolean("starforge.performance.use-game-event-cache", true, "Cache Bukkit game event lookups to reduce repeated registry conversions.");
         useCustomNameOptimisation = getBoolean("starforge.performance.use-custom-name-optimisation", true, "Skip URL matching when parsing legacy custom names.");
@@ -325,6 +332,13 @@ public class EntropyConfig {
         spawnerMaxNearbyEntities = (short) Math.min(Short.MAX_VALUE, getInt("starforge.performance.spawner.custom-settings.max-nearby-entities", 6, "Spawner max nearby entities."));
         spawnerRequiredPlayerRange = (short) Math.min(Short.MAX_VALUE, getInt("starforge.performance.spawner.custom-settings.required-player-range", 16, "Spawner required player range."));
         spawnerSpawnRange = (short) Math.min(Short.MAX_VALUE, getInt("starforge.performance.spawner.custom-settings.spawn-range", 4, "Spawner spawn range."));
+        onlyTickItemsInHand = getBoolean("starforge.performance.player.only-tick-items-in-hand", true, "Only tick complex item updates for the main hand and off hand.");
+        cacheChunkPackets = getBoolean("starforge.performance.chunk.cache-packets", false, "Reuse cached outbound chunk packets when anti-xray does not need per-player rewriting.");
+        skipIdleEntitySchedulerTicks = getBoolean("starforge.performance.scheduler.skip-idle-entity-scheduler-ticks", true, "Skip entity scheduler ticking for entities without queued scheduler tasks.");
+        rewriteFramedMapTracker = getBoolean("starforge.performance.maps.rewrite-framed-map-tracker", true, "Use a cheaper framed-map update path and share packets when possible.");
+        skipMapItemDataUpdatesWithoutCraftRenderer = getBoolean("starforge.performance.maps.skip-data-updates-without-craft-renderer", false, "Skip vanilla map data updates when a map no longer uses the CraftMapRenderer.");
+        dontSavePrimedTnt = getBoolean("starforge.performance.persistence.dont-save-primed-tnt", false, "Do not save primed TNT entities when chunks unload.");
+        dontSaveFallingBlocks = getBoolean("starforge.performance.persistence.dont-save-falling-blocks", false, "Do not save falling block entities when chunks unload.");
 
         setComment("starforge.performance", "General-purpose performance options imported from Pluto.");
     }
