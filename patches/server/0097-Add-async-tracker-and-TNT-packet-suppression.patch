diff --git a/src/main/java/net/minecraft/server/level/AsyncTracker.java b/src/main/java/net/minecraft/server/level/AsyncTracker.java
new file mode 100644
index 0000000000000000000000000000000000000000..3e9598a6c4426667fbc041a2306b4250bcfc5bf4
--- /dev/null
+++ b/src/main/java/net/minecraft/server/level/AsyncTracker.java
@@ -0,0 +1,130 @@
+package net.minecraft.server.level;
+
+import com.google.common.util.concurrent.ThreadFactoryBuilder;
+import dev.orhidea.starforge.EntropyConfig;
+import net.minecraft.server.MinecraftServer;
+
+import java.util.concurrent.CountDownLatch;
+import java.util.concurrent.LinkedBlockingQueue;
+import java.util.concurrent.ThreadPoolExecutor;
+import java.util.concurrent.TimeUnit;
+
+public final class AsyncTracker {
+
+    private static final Object EXECUTOR_LOCK = new Object();
+    private static final ThreadLocal<Boolean> TRACKER_THREAD = ThreadLocal.withInitial(() -> Boolean.FALSE);
+    private static volatile ThreadPoolExecutor executor;
+    private static volatile int configuredThreads = -1;
+
+    private AsyncTracker() {
+    }
+
+    static boolean isTrackerThread() {
+        return TRACKER_THREAD.get();
+    }
+
+    static void process(final ChunkMap chunkMap, final ChunkMap.TrackedEntity[] trackers) {
+        final int threadCount = Math.min(Math.max(1, EntropyConfig.asyncTrackerThreads), trackers.length);
+        if (threadCount <= 1) {
+            for (final ChunkMap.TrackedEntity tracker : trackers) {
+                processTracker(chunkMap, tracker);
+            }
+            chunkMap.drainTrackerMainThreadTasks(Integer.MAX_VALUE);
+            return;
+        }
+
+        final ThreadPoolExecutor executor = AsyncTracker.getExecutor(threadCount);
+        final CountDownLatch latch = new CountDownLatch(threadCount);
+        final int batchSize = Math.max(1, (trackers.length + threadCount - 1) / threadCount);
+
+        for (int worker = 0; worker < threadCount; ++worker) {
+            final int start = worker * batchSize;
+            final int end = Math.min(trackers.length, start + batchSize);
+            if (start >= end) {
+                latch.countDown();
+                continue;
+            }
+
+            executor.execute(() -> {
+                TRACKER_THREAD.set(Boolean.TRUE);
+                try {
+                    for (int index = start; index < end; ++index) {
+                        processTracker(chunkMap, trackers[index]);
+                    }
+                } catch (final Throwable throwable) {
+                    MinecraftServer.LOGGER.error("Failed to process async tracker slice", throwable);
+                } finally {
+                    TRACKER_THREAD.remove();
+                    latch.countDown();
+                }
+            });
+        }
+
+        boolean interrupted = false;
+        while (latch.getCount() > 0L) {
+            chunkMap.drainTrackerMainThreadTasks(256);
+            try {
+                latch.await(250L, TimeUnit.MICROSECONDS);
+            } catch (final InterruptedException ex) {
+                interrupted = true;
+                break;
+            }
+        }
+
+        chunkMap.drainTrackerMainThreadTasks(Integer.MAX_VALUE);
+        if (interrupted) {
+            Thread.currentThread().interrupt();
+        }
+    }
+
+    public static void shutdown() {
+        synchronized (EXECUTOR_LOCK) {
+            if (executor != null) {
+                executor.shutdown();
+                executor = null;
+                configuredThreads = -1;
+            }
+        }
+    }
+
+    private static void processTracker(final ChunkMap chunkMap, final ChunkMap.TrackedEntity tracker) {
+        if (!tracker.shouldLookForPlayers()) {
+            return;
+        }
+
+        if (chunkMap.hasTrackerEventListeners()) {
+            chunkMap.runOnTrackerMainThread(() -> tracker.updatePlayers(tracker.entity.getPlayersInTrackRange()));
+            return;
+        }
+
+        tracker.updatePlayers(tracker.entity.getPlayersInTrackRange());
+    }
+
+    private static ThreadPoolExecutor getExecutor(final int threadCount) {
+        synchronized (EXECUTOR_LOCK) {
+            if (executor == null || configuredThreads != threadCount) {
+                final ThreadPoolExecutor oldExecutor = executor;
+                final ThreadPoolExecutor newExecutor = new ThreadPoolExecutor(
+                    threadCount,
+                    threadCount,
+                    60L,
+                    TimeUnit.SECONDS,
+                    new LinkedBlockingQueue<>(),
+                    new ThreadFactoryBuilder()
+                        .setNameFormat("Starforge Async Tracker - %d")
+                        .setDaemon(true)
+                        .setUncaughtExceptionHandler(new net.minecraft.DefaultUncaughtExceptionHandlerWithName(MinecraftServer.LOGGER))
+                        .build()
+                );
+                newExecutor.allowCoreThreadTimeOut(true);
+                executor = newExecutor;
+                configuredThreads = threadCount;
+                if (oldExecutor != null) {
+                    oldExecutor.shutdown();
+                }
+            }
+
+            return executor;
+        }
+    }
+}
