     // Paper start - optimised tracker
+    public void runOnTrackerMainThread(final Runnable runnable) {
+        if (AsyncTracker.isTrackerThread()) {
+            this.trackerMainThreadTasks.add(runnable);
+        } else {
+            runnable.run();
+        }
+    }
+
+    void drainTrackerMainThreadTasks(final int maxTasks) {
+        int processed = 0;
+        while (processed < maxTasks) {
+            final Runnable task = this.trackerMainThreadTasks.poll();
+            if (task == null) {
+                break;
+            }
+            task.run();
+            ++processed;
+        }
+    }
+
+    boolean hasTrackerEventListeners() {
+        return io.papermc.paper.event.player.PlayerTrackEntityEvent.getHandlerList().getRegisteredListeners().length != 0;
+    }
+
     private final void processTrackQueue() {
