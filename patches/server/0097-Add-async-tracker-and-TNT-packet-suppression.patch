+            final TrackedEntity[] trackers = this.entityMap.values().toArray(new TrackedEntity[0]);
+            AsyncTracker.process(this, trackers);
+            this.drainTrackerMainThreadTasks(Integer.MAX_VALUE);
+            for (final TrackedEntity tracker : trackers) {
+                tracker.serverEntity.sendChanges();
+            }
+            return;
+        }
