From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: stan <dusek.s03@htlwienwest.at>
Date: Tue, 6 Dec 2022 23:03:02 +0100
Subject: [PATCH] Eye Height Parity


diff --git a/src/main/java/net/minecraft/world/level/Explosion.java b/src/main/java/net/minecraft/world/level/Explosion.java
index 0b938288cf84fdb3308b1e9cbb758ae8ec163eb1..59726d579bdefdb77855bc0ec23325cd352e48e2 100644
--- a/src/main/java/net/minecraft/world/level/Explosion.java
+++ b/src/main/java/net/minecraft/world/level/Explosion.java
@@ -18,6 +18,7 @@ import net.minecraft.world.entity.Entity;
 import net.minecraft.world.entity.LivingEntity;
 import net.minecraft.world.entity.boss.EnderDragonPart;
 import net.minecraft.world.entity.boss.enderdragon.EnderDragon;
+import net.minecraft.world.entity.item.FallingBlockEntity;
 import net.minecraft.world.entity.item.ItemEntity;
 import net.minecraft.world.entity.item.PrimedTnt;
 import net.minecraft.world.entity.monster.Creeper;
@@ -295,7 +296,7 @@ public class Explosion {
 
                 if (d7 <= 1.0D) {
                     double d8 = entity.getX() - this.x;
-                    double d9 = (entity instanceof PrimedTnt ? entity.getY() : entity.getEyeY()) - this.y;
+                    double d9 = (entity instanceof PrimedTnt || (EntropyConfig.entityEyeHeightParity && entity instanceof FallingBlockEntity) ? entity.getY() : entity.getEyeY()) - this.y; // Entropy - entity eye height parity
                     double d10 = entity.getZ() - this.z;
                     double d11 = Math.sqrt(d8 * d8 + d9 * d9 + d10 * d10);
 
diff --git a/src/main/java/xyz/fragmentmc/entropy/EntropyConfig.java b/src/main/java/xyz/fragmentmc/entropy/EntropyConfig.java
index 3a729450ef20642f38b0f2613faadcce06b06051..05245e97448e14d34a41b6491cedaeb6121aef40 100644
--- a/src/main/java/xyz/fragmentmc/entropy/EntropyConfig.java
+++ b/src/main/java/xyz/fragmentmc/entropy/EntropyConfig.java
@@ -241,6 +241,7 @@ public class EntropyConfig {
 
     public static boolean disableWaterPushingTNT;
     public static boolean disableTNTSpread;
+    public static boolean entityEyeHeightParity;
     public static boolean explodeWaterloggedBlocks;
     public static boolean explodeLava;
     public static boolean mergeEntities;
@@ -262,6 +263,9 @@ public class EntropyConfig {
                 "Disable TNT getting pushed by water (aka. Waterflow).");
         disableTNTSpread = getBoolean("entropy.patches.disable-tnt-spread", true,
                 "Disable the random velocity TNT gets when ignited.");
+        entityEyeHeightParity = getBoolean("entropy.patches.entity-eye-height-parity", false,
+                "Change the fallingBlock exposure point to the same value as the TNT exposure point.",
+                        "This is similar to 1.8 cannoning and should not be enabled without notifying players.");
         explodeWaterloggedBlocks= getBoolean("entropy.patches.explode-waterlogged-blocks", true,
                 "Waterlogged blocks will be destroyed by explosions.",
                 "This can be used to prevent unraidable bases.");
