+package xyz.fragmentmc.entropy;
+
+import net.minecraft.world.entity.player.Player;
+
+import java.util.HashMap;
+import java.util.UUID;
+
+public class EntropyUserManager {
+    public static final EntropyUserManager Instance = new EntropyUserManager();
+
+    private final HashMap<UUID, FpsData> PlayerFpsData;
+
+    private EntropyUserManager() {
+        PlayerFpsData = new HashMap<>();
+    }
+
+    public FpsData getFpsData(Player player) {
+        FpsData data = PlayerFpsData.get(player.getUUID());
+        if (data == null) {
+            FpsData nd = new FpsData(false, false, false, false, false, false, false);
+            PlayerFpsData.put(player.getUUID(), nd);
+            return nd;
+        }
+        return data;
+    }
+
+    public static final class FpsData {
+        public boolean TntHidden;
+        public boolean SandHidden;
+        public boolean AnvilHidden;
+        public boolean ConcreteHidden;
+        public boolean ExplosionHidden;
+        public boolean FlashHidden;
+        public boolean PistonHidden;
+
+        public FpsData(
+                boolean TntHidden, boolean SandHidden, boolean AnvilHidden, boolean ConcreteHidden,
+                boolean ExplosionHidden, boolean FlashHidden, boolean PistonHidden
+        ) {
+            this.TntHidden = TntHidden;
+            this.SandHidden = SandHidden;
+            this.AnvilHidden = AnvilHidden;
+            this.ConcreteHidden = ConcreteHidden;
+            this.ExplosionHidden = ExplosionHidden;
+            this.FlashHidden = FlashHidden;
+            this.PistonHidden = PistonHidden;
+        }
+    }
+}
