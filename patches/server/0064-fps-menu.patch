@@ -0,0 +1,64 @@
+package xyz.fragmentmc.entropy.gui;
+
+import net.minecraft.world.entity.player.Player;
+import org.bukkit.Bukkit;
+import org.bukkit.ChatColor;
+import org.bukkit.Material;
+import org.bukkit.inventory.Inventory;
+import org.bukkit.inventory.ItemStack;
+import org.bukkit.inventory.meta.ItemMeta;
+import xyz.fragmentmc.entropy.EntropyConfig;
+
+import java.util.HashMap;
+
+public abstract class EntropyGuiBase {
+    public static HashMap<String, InventoryWrapper> Inventories = new HashMap<>();
+
+    public EntropyGuiBase(Player player, int size) {
+        this.player = player;
+        this.size = size;
+    }
+
+    public static ItemStack getFiller() {
+        ItemStack filler = new ItemStack(Material.valueOf(EntropyConfig.guiBackgroundItem.toUpperCase()));
+        ItemMeta fillerMeta = filler.getItemMeta();
+        fillerMeta.setDisplayName(ChatColor.RESET + "");
+        filler.setItemMeta(fillerMeta);
+        return filler;
+    }
+    private final Player player;
+    public Player getPlayer() {
+        return player;
+    }
+    private final int size;
+    protected abstract HashMap<Integer, ItemStack> getInventoryItems(Player player);
+    public abstract String getInventoryTitle(Player player);
+    protected abstract String getInventoryKey(Player player);
+    public abstract void handleClick(Player player, ItemStack itemStack, int slot);
+
+    private Inventory getInventory() {
+        // TODO: Adventure API
+        Inventory inventory = Bukkit.createInventory(player.getBukkitEntity(), size, getInventoryTitle(player).replaceAll("&", "§"));
+        ItemStack filler = getFiller();
+        for (int i = 0; i < size; i++) {
+            inventory.setItem(i, filler);
+        }
+        getInventoryItems(player).forEach(inventory::setItem);
+
+        return inventory;
+    }
+
+    public void Show() {
+        Inventory inventory = getInventory();
+        Inventories.put(getInventoryKey(player), new InventoryWrapper(this, inventory));
+        player.getBukkitEntity().openInventory(inventory);
+    }
+
+    public void Update() {
+        Inventory inventory = getInventory();
+        Inventories.put(getInventoryKey(player), new InventoryWrapper(this, inventory));
+        player.getBukkitEntity().openInventory(inventory);
+    }
+
+    public record InventoryWrapper(EntropyGuiBase gui, Inventory inventory) {}
+}
