+package xyz.fragmentmc.entropy.gui.guis;
+
+import net.minecraft.world.entity.player.Player;
+import org.bukkit.ChatColor;
+import org.bukkit.Material;
+import org.bukkit.enchantments.Enchantment;
+import org.bukkit.inventory.ItemFlag;
+import org.bukkit.inventory.ItemStack;
+import org.bukkit.inventory.meta.ItemMeta;
+import xyz.fragmentmc.entropy.EntropyConfig;
+import xyz.fragmentmc.entropy.EntropyUserManager;
+import xyz.fragmentmc.entropy.gui.EntropyGuiBase;
+
+import java.util.HashMap;
+
+public class FpsGui extends EntropyGuiBase {
+    public FpsGui(Player player) {
+        super(player, 36);
+    }
+
+    private ItemStack createItem(Material material, String setting, boolean enabled) {
+        ItemStack item = new ItemStack(material);
+        ItemMeta meta = item.getItemMeta();
+        meta.setDisplayName(ChatColor.WHITE + setting + ": " + (enabled ? "§aEnabled" : "§cDisabled"));
+        meta.addItemFlags(ItemFlag.HIDE_ENCHANTS);
+        if (enabled) meta.addEnchant(Enchantment.ARROW_INFINITE, 1984, true);
+        item.setItemMeta(meta);
+        return item;
+    }
+
+    private void sendMessage(Player player, String setting, boolean enabled) {
+        if (!EntropyConfig.sendFpsMessage) return;
+        String message = EntropyConfig.fpsMessage
+                .replaceAll("%status%", enabled ? "enabled" : "disabled")
+                .replaceAll("%status_icon%", enabled ? "+" : "-")
+                .replaceAll("%status_color%", enabled ? "&a" : "&c")
+                .replaceAll("%setting%", setting)
+                .replaceAll("&", "§");
+        player.getBukkitEntity().sendMessage(message);
+    }
+
+    @Override
+    protected HashMap<Integer, ItemStack> getInventoryItems(Player player) {
+        HashMap<Integer, ItemStack> items = new HashMap<>();
+        EntropyUserManager.FpsData fpsData = EntropyUserManager.Instance.getFpsData(player);
+
+        items.put(10, createItem(Material.TNT, "Hide TNT", fpsData.TntHidden));
+        items.put(20, createItem(Material.SAND, "Hide Sand", fpsData.SandHidden));
+        items.put(12, createItem(Material.ANVIL, "Hide Anvils", fpsData.AnvilHidden));
+        items.put(22, createItem(Material.BLUE_CONCRETE_POWDER, "Hide Concrete", fpsData.ConcreteHidden));
+        items.put(14, createItem(Material.COBWEB, "Hide Explosions", fpsData.ExplosionHidden));
+        items.put(24, createItem(Material.REDSTONE_LAMP, "TNT Flash", !fpsData.FlashHidden));
+        items.put(16, createItem(Material.PISTON, "Hide Piston Movement", fpsData.PistonHidden));
+
+        return items;
+    }
+
+    @Override
+    public String getInventoryTitle(Player player) {
+        return EntropyConfig.fpsTitle.replaceAll("%player%", player.getName().getString());
+    }
+
+    @Override
+    protected String getInventoryKey(Player player) {
+        return "Fps_" + player.getUUID();
+    }
+
+    @Override
+    public void handleClick(Player player, ItemStack itemStack, int slot) {
+        EntropyUserManager.FpsData fpsData = EntropyUserManager.Instance.getFpsData(player);
+        boolean interact = true;
+        switch (slot) {
+            case 10:
+                fpsData.TntHidden = !fpsData.TntHidden;
+                sendMessage(player, "Hide TNT", fpsData.TntHidden);
+                break;
+            case 20:
+                fpsData.SandHidden = !fpsData.SandHidden;
+                sendMessage(player, "Hide Sand", fpsData.SandHidden);
+                break;
+            case 12:
+                fpsData.AnvilHidden = !fpsData.AnvilHidden;
+                sendMessage(player, "Hide Anvils", fpsData.AnvilHidden);
+                break;
+            case 22:
+                fpsData.ConcreteHidden = !fpsData.ConcreteHidden;
+                sendMessage(player, "Hide Concrete", fpsData.ConcreteHidden);
+                break;
+            case 14:
+                fpsData.ExplosionHidden = !fpsData.ExplosionHidden;
+                sendMessage(player, "Hide Explosions", fpsData.ExplosionHidden);
+                break;
+            case 24:
+                fpsData.FlashHidden = !fpsData.FlashHidden;
+                sendMessage(player, "TNT Flash", !fpsData.FlashHidden);
+                break;
+            case 16:
+                fpsData.PistonHidden = !fpsData.PistonHidden;
+                sendMessage(player, "Hide Piston Movement", fpsData.PistonHidden);
+                break;
+            default:
+                interact = false;
+                break;
+        }
+        if (interact) Update();
+    }
+}
