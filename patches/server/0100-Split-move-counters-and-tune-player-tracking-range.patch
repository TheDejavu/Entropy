+
+    private static int applyPlayerTrackingRangeMultiplier(final int range) {
+        final double multiplier = EntropyConfig.playerTrackingRangeMultiplier;
+        if (multiplier == 1.0D) {
+            return range;
+        }
+
+        return Math.max(1, Mth.floor(range * multiplier));
+    }
+
+    private static int applyTrackingRangeTypeMultiplier(final org.spigotmc.TrackingRange.TrackingRangeType trackingRangeType, final int range) {
+        return trackingRangeType == org.spigotmc.TrackingRange.TrackingRangeType.PLAYER ? applyPlayerTrackingRangeMultiplier(range) : range;
+    }
+
+    private static int applyEntityTrackingRangeMultiplier(final Entity entity, final int range) {
+        return entity instanceof ServerPlayer ? applyPlayerTrackingRangeMultiplier(range) : range;
+    }
