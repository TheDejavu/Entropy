@@ -1108,13 +1117,17 @@ public class Connection extends SimpleChannelInboundHandler<Packet<?>> {
         }
     }
 
-    private void trackSentPacketCategory(final Packet<?> packet) {
+    private void trackSentPacketCategory(final Packet<?> packet, @Nullable final Player observer) {
         if (packet instanceof ClientboundLevelChunkWithLightPacket || packet instanceof ClientboundChunksBiomesPacket || packet instanceof ClientboundForgetLevelChunkPacket) {
             ++this.chunkPacketCount;
         } else if (packet instanceof ClientboundAddEntityPacket || packet instanceof ClientboundRemoveEntitiesPacket) {
             ++this.addEntityPacketCount;
         } else if (packet instanceof ClientboundMoveEntityPacket || packet instanceof ClientboundTeleportEntityPacket || packet instanceof ClientboundRotateHeadPacket || packet instanceof ClientboundSetEntityMotionPacket) {
-            ++this.movePacketCount;
+            if (this.isPlayerMovementPacket(packet, observer)) {
+                ++this.playerMovePacketCount;
+            } else {
+                ++this.nonPlayerMovePacketCount;
+            }
         } else if (packet instanceof ClientboundSetEntityDataPacket) {
             ++this.metadataPacketCount;
         } else if (packet instanceof ClientboundSetEquipmentPacket) {
@@ -1132,6 +1145,27 @@ public class Connection extends SimpleChannelInboundHandler<Packet<?>> {
         }
     }
 
+    private boolean isPlayerMovementPacket(final Packet<?> packet, @Nullable final Player observer) {
+        if (observer == null) {
+            return false;
+        }
+
+        final Entity entity;
+        if (packet instanceof ClientboundMoveEntityPacket movePacket) {
+            entity = movePacket.getEntity(observer.level());
+        } else if (packet instanceof ClientboundRotateHeadPacket rotateHeadPacket) {
+            entity = rotateHeadPacket.getEntity(observer.level());
+        } else if (packet instanceof ClientboundTeleportEntityPacket teleportEntityPacket) {
+            entity = observer.level().getEntity(teleportEntityPacket.getId());
+        } else if (packet instanceof ClientboundSetEntityMotionPacket setEntityMotionPacket) {
+            entity = observer.level().getEntity(setEntityMotionPacket.getId());
+        } else {
+            return false;
+        }
+
+        return entity instanceof Player;
+    }
+
     private static class InnerUtil { // Attempt to hide these methods from ProtocolLib, so it doesn't accidently pick them up.
 
         @Nullable
