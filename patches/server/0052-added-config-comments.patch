@@ -280,6 +282,8 @@ public class EntropyConfig {
                 "Disable block breaking checks when tnt explodes while submerged.");
         skipRayOrigin= getBoolean("entropy.optimizations.skip-ray-origin", true,
                 "Skip the origin of explosion rays, as it gets checked with every ray.");
+        setComment("entropy.optimizations", "Changes that improve cannoning performance");
