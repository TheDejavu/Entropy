         unbreakableBreaker= getBoolean("entropy.unbreakable-breaker.enabled", true,
                 "Assigns unbreakable blocks like obsidian a durability so they can be broken by tnt.");
         unbreakableCreeper= getBoolean("entropy.unbreakable-breaker.allow-creepers", false,
@@ -300,7 +307,6 @@ public class EntropyConfig {
         durabilityCheckMessage= getString("entropy.unbreakable-breaker.durability-check-message", "&a[+] &7This block has %dura%/%max% durability.",
