@@ -1,5 +1,7 @@
 package dev.orhidea.starforge;
 
+import com.destroystokyo.paper.util.maplist.ReferenceList;
+import io.papermc.paper.util.player.NearbyPlayers;
 import net.minecraft.world.entity.Entity;
 import net.minecraft.world.entity.ExperienceOrb;
 import net.minecraft.world.entity.item.ItemEntity;
@@ -54,12 +56,26 @@ public class EntropyUserManager {
         int nearbyPlayers = 0;
         int requiredPlayers = data.HotspotActive ? EntropyConfig.hotspotDisableThreshold : EntropyConfig.hotspotEnableThreshold;
 
-        for (ServerPlayer other : player.serverLevel().players()) {
-            if (other.isRemoved()) {
-                continue;
+        ReferenceList<ServerPlayer> hotspotCandidates = this.getHotspotCandidates(player, radius);
+        if (hotspotCandidates != null) {
+            Object[] rawData = hotspotCandidates.getRawData();
+            for (int i = 0, len = hotspotCandidates.size(); i < len; ++i) {
+                ServerPlayer other = (ServerPlayer) rawData[i];
+                if (other.isRemoved()) {
+                    continue;
+                }
+                if (player.distanceToSqr(other) <= radiusSquared && ++nearbyPlayers >= requiredPlayers) {
+                    break;
+                }
             }
-            if (player.distanceToSqr(other) <= radiusSquared && ++nearbyPlayers >= requiredPlayers) {
-                break;
+        } else {
+            for (ServerPlayer other : player.serverLevel().players()) {
+                if (other.isRemoved()) {
+                    continue;
+                }
+                if (player.distanceToSqr(other) <= radiusSquared && ++nearbyPlayers >= requiredPlayers) {
+                    break;
+                }
             }
         }
 
@@ -75,6 +91,25 @@ public class EntropyUserManager {
         player.trackingRangeModifier = hotspotActive ? EntropyConfig.hotspotTrackingRangeModifier : 1.0D;
     }
 
+    private ReferenceList<ServerPlayer> getHotspotCandidates(ServerPlayer player, double radius) {
+        NearbyPlayers.NearbyMapType type;
+        if (radius <= NearbyPlayers.GENERAL_REALLY_SMALL_AREA_VIEW_DISTANCE_BLOCKS) {
+            type = NearbyPlayers.NearbyMapType.GENERAL_REALLY_SMALL;
+        } else if (radius <= NearbyPlayers.GENERAL_SMALL_AREA_VIEW_DISTANCE_BLOCKS) {
+            type = NearbyPlayers.NearbyMapType.GENERAL_SMALL;
+        } else if (radius <= NearbyPlayers.GENERAL_AREA_VIEW_DISTANCE_BLOCKS) {
+            type = NearbyPlayers.NearbyMapType.GENERAL;
+        } else {
+            return null;
+        }
+
+        return player.serverLevel().chunkSource.chunkMap.getNearbyPlayers().getPlayersByBlock(
+            player.getBlockX(),
+            player.getBlockZ(),
+            type
+        );
+    }
+
     public static final class FpsData {
         public boolean TntHidden;
         public boolean SandHidden;
