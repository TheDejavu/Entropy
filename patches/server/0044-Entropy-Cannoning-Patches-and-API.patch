@@ -0,0 +1,21 @@
+package xyz.fragmentmc.entropy.util;
+
+import net.minecraft.world.entity.Entity;
+import org.bukkit.World;
+import org.bukkit.util.Vector;
+
+import java.util.UUID;
+
+public class CannonUtil {
+    public static boolean isInCannon(Entity entity) {
+        Vector originVector = entity.getOriginVector();
+        UUID originWorld = entity.getOriginWorld();
+
+
+        if(originVector == null ||originWorld != entity.level.getWorld().getUID()) return true;
+
+        double x = originVector.getX() - entity.getX();
+        double z = originVector.getZ() - entity.getZ();
+        return x * x + z * z < 64 * 64;
+    }
+}
