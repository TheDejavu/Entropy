+    public boolean shouldFlushDirty(int tickCount, int interval) {
+        if (this.isFirstPacket) {
+            return true;
+        }
+
+        return (!this.rootsToUpdate.isEmpty() || !this.progressChanged.isEmpty()) && (interval <= 1 || tickCount % interval == 0);
+    }
