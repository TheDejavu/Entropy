+        alwaysMoistSugarCane = getBoolean("starforge.performance.always-moist.sugar-cane", false, "Allow sugar cane survival checks to skip nearby-water scans.");
+        cactusCheckSurvivalBeforeGrowth = getBoolean("starforge.performance.cactus.check-survival-before-growth", false, "Check whether a cactus can survive before attempting growth.");
+        lessRandomDispensing = getBoolean("starforge.performance.dispenser.less-random-dispensing", false, "Choose the first valid dispenser slot instead of a random valid slot.");
+        disableDropperInventoryMoveEvent = getBoolean("starforge.performance.dropper.disable-inventory-move-event", false, "Skip InventoryMoveItemEvent when droppers push into inventories.");
+        disableAllayGameEventListening = getBoolean("starforge.performance.allay.disable-game-event-listener", false, "Disable allay vibration listeners for better performance.");
+        disableAllayDuplication = getBoolean("starforge.performance.allay.disable-duplication", false, "Disable allay duplication.");
+        removeExcessMinecarts = getBoolean("starforge.performance.vehicle-cleanup.minecarts.enabled", false, "Remove excess minecarts during collision scans.");
+        removeExcessBoats = getBoolean("starforge.performance.vehicle-cleanup.boats.enabled", false, "Remove excess boats during collision scans.");
+        excessMinecartsLimit = Math.max(0, getInt("starforge.performance.vehicle-cleanup.minecarts.limit", 10, "Maximum minecarts to tolerate during a single collision scan before removal starts."));
+        excessBoatsLimit = Math.max(0, getInt("starforge.performance.vehicle-cleanup.boats.limit", 10, "Maximum boats to tolerate during a single collision scan before removal starts."));
+        disableTntChainReaction = getBoolean("starforge.performance.tnt.disable-chain-reaction", false, "Disable TNT priming from explosions.");
+        disableShulkersDroppingContentsWhenDestroyed = getBoolean("starforge.performance.shulker.disable-drop-contents-when-destroyed", false, "Prevent shulker boxes from dropping their contents when destroyed as items.");
+        disableShulkerSplitting = getBoolean("starforge.performance.shulker.disable-splitting", false, "Disable shulker splitting from shulker bullets.");
+        disableShulkerTeleporting = getBoolean("starforge.performance.shulker.disable-teleporting", false, "Disable random shulker teleports.");
 
         setComment("starforge.performance", "General-purpose performance options imported from Pluto.");
     }
