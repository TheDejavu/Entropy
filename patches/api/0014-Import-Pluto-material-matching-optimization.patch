From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Dejavu <thedeejayv1@gmail.com>
Date: Sun, 8 Mar 2026 16:00:28 +0200
Subject: [PATCH] Import Pluto material matching optimization


diff --git a/src/main/java/org/bukkit/Material.java b/src/main/java/org/bukkit/Material.java
index ec117c47401ea1a04beb0e5ee9d4d394db7c5c4e..ae92d23460a0d84f3e2f733d3ec74c64ac203257 100644
--- a/src/main/java/org/bukkit/Material.java
+++ b/src/main/java/org/bukkit/Material.java
@@ -6153,6 +6153,22 @@ public enum Material implements Keyed, Translatable, net.kyori.adventure.transla
         return matchMaterial(name, false);
     }
 
+    private static boolean isWhitespace(int c) {
+        return c == ' ' || c == '\n' || c == '\t' || c == '\r' || c == '\f';
+    }
+
+    private static boolean isLetterOrDigit(int c) {
+        return (c >= 'A' && c <= 'Z') || c == '_' || (c >= '0' && c <= '9');
+    }
+
+    private static char toUpperCaseAscii(char c) {
+        return (c >= 'a' && c <= 'z') ? (char) (c - 32) : c;
+    }
+
+    private static boolean isLowerCaseAscii(char c) {
+        return c >= 'a' && c <= 'z';
+    }
+
     /**
      * Attempts to match the Material with the given name.
      * <p>
@@ -6174,9 +6190,47 @@ public enum Material implements Keyed, Translatable, net.kyori.adventure.transla
             filtered = filtered.substring((NamespacedKey.MINECRAFT + ":").length());
         }
 
-        filtered = filtered.toUpperCase(java.util.Locale.ENGLISH);
+        char[] chars = filtered.toCharArray();
+        boolean changed = false;
+        int oldLength = chars.length;
+        int newLength = oldLength;
+
+        for (int i = 0; i < oldLength; i++) {
+            if (isLetterOrDigit(chars[i])) {
+                continue;
+            }
+
+            if (isLowerCaseAscii(chars[i])) {
+                chars[i] = toUpperCaseAscii(chars[i]);
+                changed = true;
+                continue;
+            }
+
+            if (isWhitespace(chars[i])) {
+                chars[i] = '_';
+                changed = true;
+                continue;
+            }
 
-        filtered = filtered.replaceAll("\\s+", "_").replaceAll("\\W", "");
+            chars[i] = '\0';
+            newLength--;
+            changed = true;
+        }
+
+        if (changed) {
+            if (newLength != oldLength) {
+                char[] newChars = new char[newLength];
+                int index = 0;
+                for (int i = 0; i < oldLength; i++) {
+                    if (chars[i] == '\0') {
+                        continue;
+                    }
+                    newChars[index++] = chars[i];
+                }
+                chars = newChars;
+            }
+            filtered = new String(chars);
+        }
         return getMaterial(filtered, legacyName);
     }
 
