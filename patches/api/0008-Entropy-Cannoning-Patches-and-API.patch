--- /dev/null
+++ b/src/main/java/xyz/fragmentmc/entropy/event/base/EntropyFallingBlockEvent.java
@@ -0,0 +1,17 @@
+package xyz.fragmentmc.entropy.event.base;
+
+import org.jetbrains.annotations.NotNull;
+import xyz.fragmentmc.entropy.entity.EntropyFallingBlock;
+
+public abstract class EntropyFallingBlockEvent extends EntropyBooleanEvent {
+    private final EntropyFallingBlock fallingBlock;
+
+    public EntropyFallingBlockEvent(boolean value, @NotNull EntropyFallingBlock fallingBlock) {
+        super(value);
+        this.fallingBlock = fallingBlock;
+    }
+
+    public EntropyFallingBlock getFallingBlockEntity() {
+        return this.fallingBlock;
+    }
+}
