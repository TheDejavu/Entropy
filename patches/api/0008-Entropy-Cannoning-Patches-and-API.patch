Subject: [PATCH] Entropy Cannoning Patches and API


diff --git a/src/main/java/xyz/fragmentmc/entropy/event/BubbleColumnEvent.java b/src/main/java/xyz/fragmentmc/entropy/event/BubbleColumnEvent.java
new file mode 100644
index 0000000000000000000000000000000000000000..f4b1f9181b4331e43eed4e9bed1b328e2d5e7bd3
--- /dev/null
+++ b/src/main/java/xyz/fragmentmc/entropy/event/BubbleColumnEvent.java
@@ -0,0 +1,23 @@
+package xyz.fragmentmc.entropy.event;
+
+import org.bukkit.Location;
+import org.bukkit.entity.Entity;
+import xyz.fragmentmc.entropy.event.base.EntropyBooleanEvent;
+
+public class BubbleColumnEvent extends EntropyBooleanEvent {
+    private final Entity entity;
+    private final Location location;
+    public BubbleColumnEvent(boolean value, Entity entity, Location location) {
+        super(value);
+        this.entity = entity;
+        this.location = location;
+    }
+
+    public Entity getEntity() {
+        return entity;
+    }
+
+    public Location getLocation() {
+        return location;
+    }
+}
